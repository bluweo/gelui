---
import DSLayout from "@/layouts/DSLayout.astro";
---

<DSLayout
  title="Primitives — GelUI Design System"
  description="Single-purpose building blocks of GelUI: Text, Box, Button, Input, Badge, and more. The foundational elements for composing complex glassmorphism interfaces."
  keywords="UI primitives, glass buttons, gel inputs, badges, toggles, form elements, glassmorphism components"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">

    <div class="col-span-full mb-2">
      <h1 class="text-[24px] font-[650] tracking-[-0.02em] leading-tight">Primitives</h1>
      <p class="text-[13px] mt-1 opacity-50">Single-purpose building blocks: Text, Box, Button, Input, Badge, and more.</p>
    </div>

    <div class="col-span-full glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-8 flex flex-col items-center justify-center min-h-[280px] gap-4">
      <span class="text-[48px] font-[650] opacity-10">L3</span>
      <span class="text-[15px] font-[550] opacity-60">Coming in Phase 2</span>
      <p class="text-[12px] opacity-35 max-w-[400px] text-center font-mono">
        Primitive components (Text, Box, Button, Input, Badge, Toggle, Avatar) will be documented here with live examples and API references.
      </p>
    </div>

  </div>
</DSLayout>
