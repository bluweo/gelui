---
import DSLayout from "@/components/layout/DSLayout.astro";
import PrimitivesHero from "@/components/block/PrimitivesHero.astro";
import { TypePresetsTable } from "@/components/block/TypePresetsTable";
import { PrimitiveControls } from "@/components/block/PrimitiveControls";
import { InputFieldsDemo } from "@/components/block/InputFieldsDemo";
import { PrimitiveNavigation } from "@/components/block/PrimitiveNavigation";
import { SliderDemo } from "@/components/block/SliderDemo";
import { ControlsDemo } from "@/components/block/ControlsDemo";
import { GlassControlsDemo } from "@/components/block/GlassControlsDemo";
import { ButtonsShowcase } from "@/components/block/ButtonsShowcase";
import { BadgesShowcase } from "@/components/block/BadgesShowcase";
import { FeedbackShowcase } from "@/components/block/FeedbackShowcase";

/* ─── Spacing ─── */
const spacingComps = [
  { name: "xs", value: "8px", desc: "Tight elements" },
  { name: "sm", value: "12px", desc: "Compact UI" },
  { name: "md", value: "16px", desc: "Standard" },
  { name: "lg", value: "20px", desc: "Comfortable" },
  { name: "xl", value: "24px", desc: "Generous" },
];

/* ─── Elevation ─── */
const elevations = [
  { name: "Flat", shadow: "none", z: "0", desc: "No elevation" },
  { name: "Raised", shadow: "0 2px 8px rgba(0,0,0,0.06)", z: "100", desc: "Dropdowns" },
  { name: "Floating", shadow: "0 8px 40px rgba(0,0,0,0.08), 0 2px 12px rgba(0,0,0,0.04)", z: "300", desc: "Popovers" },
  { name: "Modal", shadow: "0 24px 80px rgba(0,0,0,0.12), 0 8px 32px rgba(0,0,0,0.06)", z: "400", desc: "Dialogs" },
  { name: "Top", shadow: "0 32px 100px rgba(0,0,0,0.18), 0 12px 40px rgba(0,0,0,0.08)", z: "600", desc: "Tooltips" },
];
---

<DSLayout
  title="Primitives — GelUI Design System"
  description="Composed building blocks that bridge tokens and components. Typography presets, button styles, glass surfaces, input fields, badges, and layout compositions."
  keywords="UI primitives, typography presets, button styles, glass surfaces, form inputs, badges, spacing, elevation"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <PrimitivesHero />

    <!-- ═══════════════════════════════════
         1. Typography Presets
         ═══════════════════════════════════ -->
    <div data-section="Typography" class="col-span-full glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Typography</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1" style="font-family: var(--font-heading)">Type Presets</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">14 typography compositions — headings, body, UI labels, and code</p>
      </div>

      <TypePresetsTable client:load />
    </div>

    <!-- ═══════════════════════════════════
         2. Buttons
         ═══════════════════════════════════ -->
    <div data-section="Buttons" class="col-span-2 relative overflow-hidden rounded-[var(--glass-radius)] p-5 border contrast-border">
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] contrast-muted mb-1">Interactive</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] contrast-text mb-1" style="font-family: var(--font-heading)">Buttons</h2>
        <p class="text-[13px] leading-[1.6] contrast-muted">Gel, glass, and ghost variants with sizes and states</p>
      </div>

      <div class="grid grid-cols-2 gap-5 max-[860px]:grid-cols-1">
        <!-- Left column: Table-based groups (from @/primitives/buttons) -->
        <ButtonsShowcase client:load />

        <!-- Right column: Gel, Glass, States — transparent, contrast-aware borders -->
        <div class="flex flex-col gap-5">
          <!-- Gel Buttons table -->
          <div class="rounded-[var(--glass-radius-sm)] overflow-hidden border contrast-border">
            <div class="px-3 py-2 border-b contrast-border">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted">Gel</span>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5 border-b contrast-border-subtle">
              <span class="text-[12px] font-[550] contrast-muted">Sizes</span>
              <div class="flex items-center gap-2.5 flex-wrap justify-end">
                <button class="gel-btn gel-btn-pill text-[13px] py-2 px-5">Small</button>
                <button class="gel-btn gel-btn-pill">Medium</button>
                <button class="gel-btn gel-btn-pill text-[17px] py-3 px-7">Large</button>
              </div>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5">
              <span class="text-[12px] font-[550] contrast-muted">Icons</span>
              <div class="flex items-center gap-2.5">
                <button class="gel-btn gel-btn-circle-sm"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></button>
                <button class="gel-btn gel-btn-circle"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 12h16M12 4v16" /></svg></button>
              </div>
            </div>
          </div>
          <!-- Glass Buttons table -->
          <div class="rounded-[var(--glass-radius-sm)] overflow-hidden border contrast-border">
            <div class="px-3 py-2 border-b contrast-border">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted">Glass</span>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5 border-b contrast-border-subtle">
              <span class="text-[12px] font-[550] contrast-muted">Pill</span>
              <button class="glass-1 glass-specular rounded-[var(--glass-radius-pill)] px-5 py-2.5 text-[14px] font-[550] cursor-pointer border-none transition-all duration-200 hover:scale-105">Glass Pill</button>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5">
              <span class="text-[12px] font-[550] contrast-muted">Rounded</span>
              <button class="glass-1 glass-specular rounded-[var(--glass-radius-sm)] px-5 py-2.5 text-[14px] font-[550] cursor-pointer border-none transition-all duration-200 hover:scale-105">Glass Rounded</button>
            </div>
          </div>
          <!-- States table -->
          <div class="rounded-[var(--glass-radius-sm)] overflow-hidden border contrast-border">
            <div class="px-3 py-2 border-b contrast-border">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted">States</span>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5 border-b contrast-border-subtle">
              <span class="text-[12px] font-[550] contrast-muted">Default</span>
              <button class="gel-btn gel-btn-pill">Default</button>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5 border-b contrast-border-subtle">
              <span class="text-[12px] font-[550] contrast-muted">Hover</span>
              <button class="gel-btn gel-btn-pill scale-105">Hover</button>
            </div>
            <div class="flex items-center justify-between px-4 py-3.5">
              <span class="text-[12px] font-[550] contrast-muted">Disabled</span>
              <button class="gel-btn gel-btn-pill opacity-50 cursor-not-allowed" disabled>Disabled</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════
         3. Glass Surfaces
         ═══════════════════════════════════ -->
    <div data-section="Surfaces" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 flex flex-col">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-5 pt-1 pl-1 shrink-0">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Material</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1" style="font-family: var(--font-heading)">Glass Surfaces</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">7 surface primitives for cards, panels, and overlays</p>
      </div>
      <div class="flex flex-col gap-2 flex-1">
        {[
          { cls: "glass-transparent", label: "Transparent", name: "glass-transparent", desc: "Border only, no blur" },
          { cls: "glass-0", label: "Subtle", name: "glass-0", desc: "Minimal blur, light tint" },
          { cls: "glass-1 glass-specular", label: "Card", name: "glass-1", desc: "Standard card surface" },
          { cls: "glass-2 glass-specular", label: "Modal", name: "glass-2", desc: "Stronger blur for dialogs" },
          { cls: "glass-3 glass-specular", label: "Overlay", name: "glass-3", desc: "Maximum blur depth" },
          { cls: "gel-glass", label: "Gel", name: "gel-glass", desc: "Volumetric inset shadows", hasShine: true },
          { cls: "", label: "Solid", name: "solid", desc: "100% opaque, no transparency", isSolid: true },
        ].map((s) => (
          <div
            class:list={[
              !s.isSolid && s.cls,
              s.isSolid && "bg-white dark:bg-[#1a1a1a] border border-black/[0.08] dark:border-white/[0.1]",
              "rounded-[var(--glass-radius-sm)] px-5 py-4 flex-1 min-h-[70px] flex items-center justify-between relative",
            ]}
          >
            {s.hasShine && <div class="gel-glass-shine"></div>}
            <div class:list={["flex flex-col gap-0.5", s.hasShine && "relative z-[3]"]}>
              <span class="text-[13px] font-[600] text-black/80 dark:text-white/80">{s.label}</span>
              <span class="text-[11px] text-black/45 dark:text-white/40 max-[540px]:hidden">{s.desc}</span>
            </div>
            <span class:list={["text-[10px] font-mono px-2 py-1 rounded-[5px] bg-black/[0.05] dark:bg-white/[0.08] text-black/45 dark:text-white/35 shrink-0", s.hasShine && "relative z-[3]"]}>{s.name}</span>
          </div>
        ))}
      </div>

    </div>

    <!-- ═══════════════════════════════════
         3b. Card Panels
         ═══════════════════════════════════ -->
    <div data-section="Card Panels" class="col-span-full">
      <div class="flex flex-col gap-1 mb-5 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] contrast-muted mb-1">Containers</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] contrast-text mb-1" style="font-family: var(--font-heading)">Card Panels</h2>
        <p class="text-[13px] leading-[1.6] contrast-muted">5 panel recipes — glass + frost + border combined into usable containers</p>
      </div>

      <div class="grid grid-cols-3 gap-5 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">

        <!-- 1. Standard Card -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 140px;" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80 px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Standard</span>
            <p class="text-[13px] font-[600] text-black/80 dark:text-white/80 mb-1">glass-1 + ds-card-frost</p>
            <p class="text-[11px] text-black/50 dark:text-white/45">Default card for text-heavy content. 95% frost ensures maximum readability on any background.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">frost-95%</span>
          </div>
        </div>

        <!-- 2. Haze Card -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none ds-card-frost-haze" style="height: 140px;" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Haze</span>
            <p class="text-[13px] font-[600] contrast-text mb-1">glass-1 + ds-card-frost-haze</p>
            <p class="text-[11px] contrast-muted">Partial see-through card. 35% frost for showcasing visual elements with some background context.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">frost-35%</span>
          </div>
        </div>

        <!-- 3. Transparent Card -->
        <div class="relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between border contrast-border">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Transparent</span>
            <p class="text-[13px] font-[600] contrast-text mb-1">border only — no glass</p>
            <p class="text-[11px] contrast-muted">Content floats directly on the wallpaper. Border-only container for gel/glass button showcases.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.06] dark:bg-white/[0.08] contrast-muted">no blur</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.06] dark:bg-white/[0.08] contrast-muted">no frost</span>
          </div>
        </div>

        <!-- 4. Plain Glass -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80 px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Plain Glass</span>
            <p class="text-[13px] font-[600] text-black/80 dark:text-white/80 mb-1">glass-1 — no frost</p>
            <p class="text-[11px] text-black/50 dark:text-white/45">Glass blur without frost overlay. For small cards, badges, or elements where content is short and readable.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">no frost</span>
          </div>
        </div>

        <!-- 5. Token Frost (left-to-right) -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none token-hero-frost" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80 px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Directional</span>
            <p class="text-[13px] font-[600] text-black/80 dark:text-white/80 mb-1">glass-1 + token-hero-frost</p>
            <p class="text-[11px] text-black/50 dark:text-white/45">Left-to-right frost. Text on the left stays readable, image/content on the right shows through.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">frost-L→R</span>
          </div>
        </div>

        <!-- 6. Solid Card -->
        <div class="relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between bg-white dark:bg-[#1a1a1a] border border-black/[0.06] dark:border-white/[0.08]">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80 px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Solid</span>
            <p class="text-[13px] font-[600] text-black/80 dark:text-white/80 mb-1">100% opaque — no glass</p>
            <p class="text-[11px] text-black/50 dark:text-white/45">Fully opaque card with no transparency, blur, or frost. Maximum contrast for data-heavy or critical content.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">no blur</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">no frost</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">opaque</span>
          </div>
        </div>

      </div>
    </div>

    <!-- ═══════════════════════════════════
         3c. Dividers
         ═══════════════════════════════════ -->
    <div data-section="Dividers" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 140px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Separator</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1" style="font-family: var(--font-heading)">Dividers</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">Visual separators for content sections and groups</p>
      </div>

      <div class="flex flex-col gap-4 flex-1">
        <!-- Horizontal -->
        <div class="rounded-[var(--glass-radius-sm)] overflow-hidden bg-white dark:bg-[#1a1a1a] flex-1">
          <div class="px-3 py-2 bg-black/[0.06] dark:bg-white/[0.08] border-b border-black/[0.08] dark:border-white/[0.08]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80">Horizontal</span>
          </div>
          <div class="flex flex-col gap-4 p-4">
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Default</span>
              <div class="w-full h-px bg-black/15 dark:bg-white/15"></div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Bold</span>
              <div class="w-full h-[2px] bg-black/25 dark:bg-white/25"></div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Dashed</span>
              <div class="w-full border-t border-dashed border-black/20 dark:border-white/20"></div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">With label</span>
              <div class="flex items-center gap-3">
                <div class="flex-1 h-px bg-black/15 dark:bg-white/15"></div>
                <span class="text-[10px] font-[550] text-black/50 dark:text-white/50 uppercase tracking-wider">or</span>
                <div class="flex-1 h-px bg-black/15 dark:bg-white/15"></div>
              </div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">With icon</span>
              <div class="flex items-center gap-3">
                <div class="flex-1 h-px bg-black/15 dark:bg-white/15"></div>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-black/40 dark:text-white/40"><circle cx="12" cy="12" r="3" /></svg>
                <div class="flex-1 h-px bg-black/15 dark:bg-white/15"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Vertical + Spacing -->
        <div class="rounded-[var(--glass-radius-sm)] overflow-hidden bg-white dark:bg-[#1a1a1a] flex-1">
          <div class="px-3 py-2 bg-black/[0.06] dark:bg-white/[0.08] border-b border-black/[0.08] dark:border-white/[0.08]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80">Vertical & Spacing</span>
          </div>
          <div class="flex flex-col gap-4 p-4">
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Vertical divider</span>
              <div class="flex items-center gap-4 h-[40px]">
                <span class="text-[11px] text-black/70 dark:text-white/70">Left</span>
                <div class="w-px h-full bg-black/20 dark:bg-white/20"></div>
                <span class="text-[11px] text-black/70 dark:text-white/70">Right</span>
              </div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Inset divider</span>
              <div class="px-4">
                <div class="w-full h-px bg-black/15 dark:bg-white/15"></div>
              </div>
            </div>
            <div>
              <span class="text-[10px] font-[500] text-black/70 dark:text-white/70 mb-2 block">Gradient fade</span>
