---
import DSLayout from "@/components/layout/DSLayout.astro";
import PrimitivesHero from "@/components/block/PrimitivesHero.astro";
import { TypePresetsTable } from "@/components/block/TypePresetsTable";
import { PrimitiveControls } from "@/components/block/PrimitiveControls";
import { InputFieldsDemo } from "@/components/block/InputFieldsDemo";
import { PrimitiveNavigation } from "@/components/block/PrimitiveNavigation";
import { SliderDemo } from "@/components/block/SliderDemo";
import { ControlsDemo } from "@/components/block/ControlsDemo";
import { GlassControlsDemo } from "@/components/block/GlassControlsDemo";
import { ButtonsShowcaseWithSource } from "@/components/block/ButtonsShowcaseWithSource";
import { BadgesShowcase } from "@/components/block/BadgesShowcase";
import { FeedbackShowcase } from "@/components/block/FeedbackShowcase";
import { ButtonsRightColumn } from "@/components/block/ButtonsRightColumn";
import { BadgesShowcaseV2 } from "@/components/block/BadgesShowcaseV2";
import { BadgesShowcaseWithSource } from "@/components/block/BadgesShowcaseWithSource";
import { FeedbackShowcaseV2 } from "@/components/block/FeedbackShowcaseV2";
import { LayoutShowcase } from "@/components/block/LayoutShowcase";
import { ElevationShowcase } from "@/components/block/ElevationShowcase";
import { FormsShowcase } from "@/components/block/FormsShowcase";
import { FormsShowcaseWithSource } from "@/components/block/FormsShowcaseWithSource";
import { DataShowcase } from "@/components/block/DataShowcase";
import { TypographyExtrasWithSource } from "@/components/block/TypographyExtrasWithSource";
import { NavigationExtras } from "@/components/block/NavigationExtras";
import { SurfacesExtrasWithSource } from "@/components/block/SurfacesExtrasWithSource";
import { GlassSurfacesSource } from "@/components/block/GlassSurfacesSource";
import { CardPanelsSource } from "@/components/block/CardPanelsSource";
import { DividersSource } from "@/components/block/DividersSource";
import { InputFieldsSource } from "@/components/block/InputFieldsSource";

/* Data moved to React islands: LayoutShowcase, ElevationShowcase */
---

<DSLayout
  title="Primitives — GelUI Design System"
  description="Composed building blocks that bridge tokens and components. Typography presets, button styles, glass surfaces, input fields, badges, and layout compositions."
  keywords="UI primitives, typography presets, button styles, glass surfaces, form inputs, badges, spacing, elevation"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <PrimitivesHero />

    <!-- ═══════════════════════════════════
         1. Typography Presets
         ═══════════════════════════════════ -->
    <div data-section="Typography" class="col-span-full glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="type-overline text-black/40 dark:text-white/40 mb-1">Typography</span>
        <h2 class="type-h2 text-black dark:text-white mb-1">Type Presets</h2>
        <p class="type-body-sm text-black/60 dark:text-white/55">14 typography compositions — headings, body, UI labels, and code</p>
      </div>

      <TypePresetsTable client:load />
    </div>

    <!-- ═══════════════════════════════════
         1b. Typography Extras
         ═══════════════════════════════════ -->
    <div data-section="Typography Extras" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex items-start justify-between mb-6 pt-1 pl-1">
        <div class="flex flex-col gap-1">
          <span class="type-overline text-black/40 dark:text-white/40 mb-1">Typography</span>
          <h2 class="type-h2 text-black dark:text-white mb-1">Typography Extras</h2>
          <p class="type-body-sm text-black/60 dark:text-white/55">Blockquotes, lists, and keyboard shortcut indicators</p>
        </div>
        <button
          class="w-9 h-9 flex items-center justify-center rounded-full bg-black/[0.04] dark:bg-white/[0.06] hover:bg-black/[0.08] dark:hover:bg-white/[0.12] border border-black/[0.06] dark:border-white/[0.08] transition-all duration-150 cursor-pointer shrink-0 z-10"
          title="View Source Code"
          data-view-source="typography-extras"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-black/50 dark:text-white/40"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
        </button>
      </div>
      <TypographyExtrasWithSource client:load />
    </div>

    <!-- ═══════════════════════════════════
         2. Buttons
         ═══════════════════════════════════ -->
    <div data-section="Buttons" class="col-span-2 relative overflow-hidden rounded-[var(--glass-radius)] p-5 border contrast-border">
      <div class="relative flex items-start justify-between mb-6 pt-1 pl-1">
        <div class="flex flex-col gap-1">
          <span class="type-overline contrast-muted mb-1">Interactive</span>
          <h2 class="type-h2 contrast-text mb-1">Buttons</h2>
          <p class="type-body-sm contrast-muted">Gel, glass, and ghost variants with sizes and states</p>
        </div>
        <button
          class="w-9 h-9 flex items-center justify-center rounded-full border contrast-border transition-all duration-150 cursor-pointer shrink-0 z-10 hover:scale-110"
          style="background: rgba(128,128,128,0.15); backdrop-filter: blur(8px);"
          title="View Source Code"
          data-view-source="buttons"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="contrast-text"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
        </button>
      </div>

      <div class="grid grid-cols-2 gap-5 max-[860px]:grid-cols-1">
        <!-- Left column: Table-based groups (from @/primitives/buttons) -->
        <ButtonsShowcaseWithSource client:load />

        <!-- Right column: Gel, Glass, States — using Button primitives -->
        <ButtonsRightColumn client:load />
      </div>
    </div>

    <!-- ═══════════════════════════════════
         3. Glass Surfaces
         ═══════════════════════════════════ -->
    <div data-section="Surfaces" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 flex flex-col">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex items-start justify-between mb-5 pt-1 pl-1 shrink-0">
        <div class="flex flex-col gap-1">
          <span class="type-overline text-black/40 dark:text-white/40 mb-1">Material</span>
          <h2 class="type-h2 text-black dark:text-white mb-1">Glass Surfaces</h2>
          <p class="type-body-sm text-black/60 dark:text-white/55">7 surface primitives for cards, panels, and overlays</p>
        </div>
        <button
          class="w-9 h-9 flex items-center justify-center rounded-full bg-black/[0.04] dark:bg-white/[0.06] hover:bg-black/[0.08] dark:hover:bg-white/[0.12] border border-black/[0.06] dark:border-white/[0.08] transition-all duration-150 cursor-pointer shrink-0 z-10 hover:scale-110"
          title="View Source Code"
          data-view-source="glass-surfaces"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-black/50 dark:text-white/40"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
        </button>
      </div>
      <div class="flex flex-col gap-2 flex-1">
        {[
          { cls: "glass-transparent", label: "Transparent", name: "glass-transparent", desc: "Border only, no blur" },
          { cls: "glass-0", label: "Subtle", name: "glass-0", desc: "Minimal blur, light tint" },
          { cls: "glass-1 glass-specular", label: "Card", name: "glass-1", desc: "Standard card surface" },
          { cls: "glass-2 glass-specular", label: "Modal", name: "glass-2", desc: "Stronger blur for dialogs" },
          { cls: "glass-3 glass-specular", label: "Overlay", name: "glass-3", desc: "Maximum blur depth" },
          { cls: "gel-glass", label: "Gel", name: "gel-glass", desc: "Volumetric inset shadows", hasShine: true },
          { cls: "", label: "Solid", name: "solid", desc: "100% opaque, no transparency", isSolid: true },
        ].map((s) => (
          <div
            class:list={[
              !s.isSolid && s.cls,
              s.isSolid && "bg-white dark:bg-[#1a1a1a] border border-black/[0.08] dark:border-white/[0.1]",
              "rounded-[var(--glass-radius-sm)] px-5 py-4 flex-1 min-h-[70px] flex items-center justify-between relative",
            ]}
          >
            {s.hasShine && <div class="gel-glass-shine"></div>}
            <div class:list={["flex flex-col gap-0.5", s.hasShine && "relative z-[3]"]}>
              <span class="text-[13px] font-[600] text-black/80 dark:text-white/80">{s.label}</span>
              <span class="text-[11px] text-black/45 dark:text-white/40 max-[540px]:hidden">{s.desc}</span>
            </div>
            <span class:list={["text-[10px] font-mono px-2 py-1 rounded-[5px] bg-black/[0.05] dark:bg-white/[0.08] text-black/45 dark:text-white/35 shrink-0", s.hasShine && "relative z-[3]"]}>{s.name}</span>
          </div>
        ))}
      </div>
      <GlassSurfacesSource client:load />

    </div>

    <!-- ═══════════════════════════════════
         3a. Surfaces Extras (Accordion + ScrollArea)
         ═══════════════════════════════════ -->
    <div data-section="Surfaces Extras" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex items-start justify-between mb-6 pt-1 pl-1">
        <div class="flex flex-col gap-1">
          <span class="type-overline text-black/40 dark:text-white/40 mb-1">Containers</span>
          <h2 class="type-h2 text-black dark:text-white mb-1">Surfaces Extras</h2>
          <p class="type-body-sm text-black/60 dark:text-white/55">Expandable sections and scrollable content areas</p>
        </div>
        <button
          class="w-9 h-9 flex items-center justify-center rounded-full bg-black/[0.04] dark:bg-white/[0.06] hover:bg-black/[0.08] dark:hover:bg-white/[0.12] border border-black/[0.06] dark:border-white/[0.08] transition-all duration-150 cursor-pointer shrink-0 z-10 hover:scale-110"
          title="View Source Code"
          data-view-source="surfaces-extras"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-black/50 dark:text-white/40"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
        </button>
      </div>
      <SurfacesExtrasWithSource client:load />
    </div>

    <!-- ═══════════════════════════════════
         3b. Card Panels
         ═══════════════════════════════════ -->
    <div data-section="Card Panels" class="col-span-2 min-[861px]:col-span-full">
      <div class="flex items-start justify-between mb-5 pl-1">
        <div class="flex flex-col gap-1">
          <span class="type-overline contrast-muted mb-1">Containers</span>
          <h2 class="type-h2 contrast-text mb-1">Card Panels</h2>
          <p class="type-body-sm contrast-muted">9 panel recipes — glass, gel, and solid variants with frost options</p>
        </div>
        <div class="flex items-center gap-2 shrink-0 z-10">
          <button
            id="card-bg-btn"
            class="prim-btn-base prim-btn-md prim-btn-pill prim-btn-solid"
            title="Change Background"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="M21 15l-5-5L5 21" /></svg>
            Background
          </button>
          <button
            id="card-appearance-btn"
            class="prim-btn-base prim-btn-md prim-btn-pill prim-btn-ghost"
            title="Appearance Settings"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M12.22 2h-.44a2 2 0 00-2 2v.18a2 2 0 01-1 1.73l-.43.25a2 2 0 01-2 0l-.15-.08a2 2 0 00-2.73.73l-.22.38a2 2 0 00.73 2.73l.15.1a2 2 0 011 1.72v.51a2 2 0 01-1 1.74l-.15.09a2 2 0 00-.73 2.73l.22.38a2 2 0 002.73.73l.15-.08a2 2 0 012 0l.43.25a2 2 0 011 1.73V20a2 2 0 002 2h.44a2 2 0 002-2v-.18a2 2 0 011-1.73l.43-.25a2 2 0 012 0l.15.08a2 2 0 002.73-.73l.22-.39a2 2 0 00-.73-2.73l-.15-.08a2 2 0 01-1-1.74v-.5a2 2 0 011-1.74l.15-.09a2 2 0 00.73-2.73l-.22-.38a2 2 0 00-2.73-.73l-.15.08a2 2 0 01-2 0l-.43-.25a2 2 0 01-1-1.73V4a2 2 0 00-2-2z" /></svg>
            Appearance
          </button>
          <button
            class="w-9 h-9 flex items-center justify-center rounded-full border contrast-border transition-all duration-150 cursor-pointer shrink-0 hover:scale-110 contrast-muted"
            style="background: rgba(128,128,128,0.15); backdrop-filter: blur(8px);"
            title="View Source Code"
            data-view-source="card-panels"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
          </button>
        </div>
        <script>
          document.getElementById('card-bg-btn')?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('gelui:open-background'));
          });
          document.getElementById('card-appearance-btn')?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('gelui:open-appearance'));
          });
        </script>
      </div>

      <div class="grid grid-cols-3 gap-5 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">

        <!-- 1. Standard Card (glass + frost = opaque surface → use glass-type text) -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 140px;" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-title px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Standard</span>
            <p class="text-[13px] font-[600] glass-type-title mb-1">glass-1 + ds-card-frost</p>
            <p class="text-[11px] glass-type-sub">Default card for text-heavy content. 95% frost ensures maximum readability on any background.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">frost-95%</span>
          </div>
        </div>

        <!-- 2. Haze Card (glass + haze frost → use glass-type text) -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none ds-card-frost-haze" style="height: 140px;" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-sub px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Haze</span>
            <p class="text-[13px] font-[600] glass-type-title mb-1">glass-1 + ds-card-frost-haze</p>
            <p class="text-[11px] glass-type-sub">Partial see-through card. 35% frost for showcasing visual elements with some background context.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">frost-35%</span>
          </div>
        </div>

        <!-- 3. Transparent Card -->
        <div class="relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between border contrast-border">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] contrast-muted px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Transparent</span>
            <p class="text-[13px] font-[600] contrast-text mb-1">border only — no glass</p>
            <p class="text-[11px] contrast-muted">Content floats directly on the wallpaper. Border-only container for gel/glass button showcases.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.06] dark:bg-white/[0.08] contrast-muted">no blur</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.06] dark:bg-white/[0.08] contrast-muted">no frost</span>
          </div>
        </div>

        <!-- 4. Plain Glass (glass surface → use glass-type text) -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-title px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Plain Glass</span>
            <p class="text-[13px] font-[600] glass-type-title mb-1">glass-1 — no frost</p>
            <p class="text-[11px] glass-type-sub">Glass blur without frost overlay. For small cards, badges, or elements where content is short and readable.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">no frost</span>
          </div>
        </div>

        <!-- 5. Token Frost (glass + directional frost → use glass-type text) -->
        <div class="glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="absolute inset-0 pointer-events-none token-hero-frost" />
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-title px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Directional</span>
            <p class="text-[13px] font-[600] glass-type-title mb-1">glass-1 + token-hero-frost</p>
            <p class="text-[11px] glass-type-sub">Left-to-right frost. Text on the left stays readable, image/content on the right shows through.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">backdrop-filter</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">frost-L→R</span>
          </div>
        </div>

        <!-- 6. Solid Card (opaque bg → use theme text) -->
        <div class="relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between bg-white dark:bg-[#1a1a1a] border border-black/[0.06] dark:border-white/[0.08]">
          <div>
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/80 dark:text-white/80 px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Solid</span>
            <p class="text-[13px] font-[600] text-black/80 dark:text-white/80 mb-1">100% opaque — no glass</p>
            <p class="text-[11px] text-black/50 dark:text-white/45">Fully opaque card with no transparency, blur, or frost. Maximum contrast for data-heavy or critical content.</p>
          </div>
          <div class="flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">no blur</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">no frost</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] text-black/40 dark:text-white/35">opaque</span>
          </div>
        </div>

        <!-- 7. Gel Standard (gel surface → use glass-type text) -->
        <div class="gel-glass glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="gel-glass-shine"></div>
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-title px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Gel Standard</span>
            <p class="text-[13px] font-[600] glass-type-title mb-1">gel-glass + specular shine</p>
            <p class="text-[11px] glass-type-sub">Volumetric gel surface with inset shadows and specular highlight. Premium feel for hero content and featured items.</p>
          </div>
          <div class="relative z-[1] flex items-center gap-2 mt-3">
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">gel-glass</span>
            <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-[4px] bg-black/[0.05] dark:bg-white/[0.08] glass-type-sub">volumetric</span>
          </div>
        </div>

        <!-- 8. Gel Floating (gel surface → use glass-type text) -->
        <div class="gel-glass glass-specular gel-card-floating relative overflow-hidden rounded-[var(--glass-radius)] p-5 min-h-[200px] flex flex-col justify-between">
          <div class="gel-glass-shine"></div>
          <div class="relative z-[1]">
            <span class="text-[10px] font-[650] uppercase tracking-[0.06em] glass-type-title px-2 py-0.5 rounded-full bg-black/[0.06] dark:bg-white/[0.08] inline-block mb-2">Gel Floating</span>
