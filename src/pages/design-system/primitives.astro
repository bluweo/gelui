            </div>
            <div class="py-3">
              <div class="flex justify-between mb-1.5"><span class="text-[11px] font-[500] text-black/55 dark:text-white/50">Complete</span><span class="text-[11px] font-mono text-black/40 dark:text-white/35">100%</span></div>
              <div class="w-full h-2 rounded-full bg-black/[0.06] dark:bg-white/[0.06] overflow-hidden"><div class="h-full rounded-full bg-green-500" style="width: 100%"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════
         10. Navigation
         ═══════════════════════════════════ -->
    <div data-section="Navigation" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Wayfinding</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1" style="font-family: var(--font-heading)">Navigation</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">Interactive tab bars, breadcrumbs, and nav items</p>
      </div>
      <PrimitiveNavigation client:load />
    </div>

  </div>
</DSLayout>
