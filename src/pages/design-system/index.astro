---
import DSLayout from "@/components/layout/DSLayout.astro";
import HeroText from "@/components/block/HeroText.astro";
import HeroBanner from "@/components/block/HeroBanner.astro";
import ArchitectureDiagram from "@/components/block/ArchitectureDiagram.astro";
import TechStack from "@/components/block/TechStack.astro";
import Features from "@/components/block/Features.astro";
import BrowserCompat from "@/components/block/BrowserCompat.astro";
import ProjectStructure from "@/components/block/ProjectStructure.astro";
import Viewports from "@/components/block/Viewports.astro";
import RightClickHint from "@/components/block/RightClickHint.astro";
---

<DSLayout
  title="Gel UI — Astro UI Design System"
  description="GelUI is a glassmorphism-first design system with volumetric gel surfaces, 10-layer shadow depth, adaptive contrast detection, and real-time appearance tuning. Built with Astro 5, React 19, and Tailwind CSS v4."
  keywords="GelUI, design system, glassmorphism, glass UI, gel surfaces, Astro, React, Tailwind CSS, dark mode, adaptive contrast, UI framework"
>
  <RightClickHint />
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <HeroText />

    <!-- Hero row: 1/3 + 2/3 -->
    <div data-section="Architecture" class="col-span-full grid grid-cols-[1fr_2fr] gap-5 max-[860px]:grid-cols-1 max-[860px]:gap-4 max-[540px]:gap-3">
      <HeroBanner />
      <ArchitectureDiagram />
    </div>
    <div data-section="Features" class="col-span-full"><Features /></div>
    <div data-section="Tech Stack" class="col-span-full"><TechStack /></div>
    <div data-section="Viewports" class="col-span-full"><Viewports /></div>
    <div data-section="Browser Support" class="col-span-full"><BrowserCompat /></div>
    <div data-section="Project Structure" class="col-span-full"><ProjectStructure /></div>

  </div>
</DSLayout>
