---
import DSLayout from "@/layouts/DSLayout.astro";
---

<DSLayout
  title="Components — GelUI Design System"
  description="Multi-primitive compositions in GelUI: Card, Modal, Dropdown, Tabs, and compound elements. Production-ready glassmorphism components with adaptive theming."
  keywords="UI components, glass cards, modals, dropdowns, tabs, compound components, glassmorphism, adaptive theming"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">

    <div class="col-span-full mb-2">
      <h1 class="text-[24px] font-[650] tracking-[-0.02em] leading-tight">Components</h1>
      <p class="text-[13px] mt-1 opacity-50">Multi-primitive compositions: Card, Modal, Dropdown, Tabs, and compound elements.</p>
    </div>

    <div class="col-span-full glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-8 flex flex-col items-center justify-center min-h-[280px] gap-4">
      <span class="text-[48px] font-[650] opacity-10">L4</span>
      <span class="text-[15px] font-[550] opacity-60">Coming in Phase 3</span>
      <p class="text-[12px] opacity-35 max-w-[400px] text-center font-mono">
        Compound components (Card, Modal, Dropdown, Tabs, Toast, ContextMenu) will be documented here with interactive demos and prop tables.
      </p>
    </div>

  </div>
</DSLayout>
