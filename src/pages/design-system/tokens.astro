---
import DSLayout from "@/layouts/DSLayout.astro";
import {
  colors,
  brand,
  typography,
  spacing,
  radii,
  shadows,
  glass,
  motion,
  breakpoints,
  zIndex,
} from "@/tokens";
import { isLightBg, textOnBg, textOnBgMuted, resolveSemanticHex } from "@/utils/color-utils";

/* ─── Helpers ─── */

function getBrandScale(key: string): Record<string, string> | null {
  const raw = colors.raw as Record<string, unknown>;
  const scale = raw[key];
  if (scale && typeof scale === "object" && "50" in scale) {
    return scale as Record<string, string>;
  }
  return null;
}

const ROLE_LABELS: Record<string, string> = { primary: "Primary", secondary: "Secondary", accent: "Accent" };
const ROLE_ORDER: Record<string, number> = { primary: 0, secondary: 1, accent: 2 };

const sortedBrand = [...brand].sort(
  (a, b) => (ROLE_ORDER[a.role ?? "accent"] ?? 2) - (ROLE_ORDER[b.role ?? "accent"] ?? 2),
);

const primaryBrand = sortedBrand.find((b) => b.role === "primary") ?? sortedBrand[0];
const primaryScale = getBrandScale(primaryBrand.key);
const baseHex = primaryScale?.["500"] ?? primaryBrand.hex;
const darkHex = primaryScale?.["800"] ?? baseHex;
const mutedHex = primaryScale?.["300"] ?? baseHex;
const tintHex = primaryScale?.["50"] ?? baseHex;
const grayHex = colors.raw.gray[500];

const derived = [
  { label: "Dark", hex: darkHex },
  { label: "Gray", hex: grayHex },
  { label: "Muted", hex: mutedHex },
  { label: "Tint", hex: tintHex },
];

const gridCols = sortedBrand.length <= 2 ? "grid-cols-2" : sortedBrand.length === 3 ? "grid-cols-3" : "grid-cols-4";

// Pre-compute entries to avoid `as` type casts in Astro template (parser can't handle them)
const radiiPresetEntries = Object.entries(radii.presets) as Array<[string, Record<string, string>]>;
const shadowPresetEntries = Object.entries(shadows.presets) as Array<[string, Record<string, string>]>;
const glassLevelEntries = Object.entries(glass.levels) as Array<[string, { blur: number; saturate: number; bgAlpha: number; label: string }]>;
const spacingRawEntries = Object.entries(spacing.raw) as Array<[string, string]>;
const fontSizeEntries = Object.entries(typography.fontSize) as Array<[string, string]>;
const fontWeightEntries = Object.entries(typography.fontWeight) as Array<[string, number]>;
const durationEntries = Object.entries(motion.duration) as Array<[string, string]>;
const easingEntries = Object.entries(motion.easing) as Array<[string, string]>;
const breakpointEntries = Object.entries(breakpoints) as Array<[string, number]>;
const zIndexEntries = Object.entries(zIndex) as Array<[string, number]>;
const semanticColorEntries = Object.entries(colors.semantic) as Array<[string, { light: string; dark: string }]>;
const textColorEntries = Object.entries(colors.text) as Array<[string, { light: string; dark: string }]>;
const radiiRawEntries = Object.entries(radii.raw) as Array<[string, string]>;
---

<DSLayout title="Design Tokens — GelUI">
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <!-- Hero Banner: Desktop (≥768px) — single card with overlay image -->
    <div class="col-span-full glass-1 glass-specular rounded-[var(--glass-radius)] overflow-hidden relative md:block hidden">
      <!-- Frost zone for readable text on left side -->
      <div class="absolute top-0 left-0 bottom-0 w-[45%] pointer-events-none z-[1] rounded-l-[var(--glass-radius)] token-hero-frost" />
      <div class="w-full min-h-[420px] max-[860px]:min-h-[340px] relative">
        <!-- Background image — right area -->
        <div class="absolute top-6 right-14 bottom-14 left-[38%] overflow-hidden rounded-[var(--glass-radius)]">
          <img
            src="/resources/images/gelui-design-token.png"
            alt="Design Token Architecture"
            class="w-full h-full object-cover object-center rounded-[var(--glass-radius)]"
          />
        </div>
        <!-- Overlaid content -->
        <div class="absolute inset-0 p-8 flex flex-col justify-between z-[2]">
          <div class="w-[36%] max-[860px]:w-[50%] flex items-start justify-between">
            <h1 class="text-[38px] max-[860px]:text-[30px] font-[700] tracking-[-0.03em] leading-[1.1] text-black dark:text-white">
              Design<br/>Tokens
            </h1>
            <div class="text-right pt-2">
              <span class="text-[11px] font-[500] leading-tight text-black/40 dark:text-white/40 block">Token</span>
              <span class="text-[11px] font-[500] leading-tight text-black/40 dark:text-white/40 block">Architecture</span>
              <span class="text-[11px] font-[500] leading-tight text-black/40 dark:text-white/40 block">2026</span>
            </div>
          </div>
          <div class="flex items-end justify-between gap-5">
            <div class="max-w-[420px]">
              <div class="flex items-center gap-2">
                <span class="text-black/30 dark:text-white/30 text-[14px] font-mono">//</span>
                <span class="text-[13px] text-black/60 dark:text-white/55 leading-relaxed">
                  The atomic building blocks of every visual decision. Our 3-tier architecture ensures consistency across themes, modes, and platforms.
                </span>
              </div>
            </div>
            <div class="flex gap-3">
              <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-5 py-4 min-w-[160px]">
                <span class="text-[22px] font-[700] text-black dark:text-white block leading-tight">3 Tiers</span>
                <span class="text-[12px] text-black/50 dark:text-white/45 block mt-0.5">Core → Semantic → Component</span>
              </div>
              <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-5 py-4 min-w-[160px]">
                <span class="text-[22px] font-[700] text-black dark:text-white block leading-tight">120+</span>
                <span class="text-[12px] text-black/50 dark:text-white/45 block mt-0.5">Tokens across color, type & space</span>
              </div>
              <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-5 py-4 min-w-[160px]">
                <span class="text-[22px] font-[700] text-black dark:text-white block leading-tight">Dark + Light</span>
                <span class="text-[12px] text-black/50 dark:text-white/45 block mt-0.5">Full theme support built-in</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Banner: Mobile/Tablet (<768px) — two col-span-2 items -->
    <div class="col-span-2 glass-1 glass-specular rounded-[var(--glass-radius)] overflow-hidden p-5 flex flex-col justify-between md:hidden relative">
      <!-- Frost zone for readable text — solid coverage -->
      <div class="absolute inset-0 pointer-events-none z-0 rounded-[var(--glass-radius)]" style="background: rgba(255,255,255,0.88);" data-frost-mobile />
      <div class="relative z-[1]">
        <div class="flex items-start justify-between mb-3">
          <h1 class="text-[22px] font-[700] tracking-[-0.03em] leading-[1.1] text-black dark:text-white">
            Design Tokens
          </h1>
          <div class="text-right pt-1 shrink-0 ml-3">
            <span class="text-[10px] font-[500] leading-tight text-black/40 dark:text-white/40 block">Token Architecture 2026</span>
          </div>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-black/30 dark:text-white/30 text-[12px] font-mono shrink-0">//</span>
          <span class="text-[12px] text-black/60 dark:text-white/55 leading-relaxed">
            The atomic building blocks of every visual decision. Our 3-tier architecture ensures consistency across themes, modes, and platforms.
          </span>
        </div>
      </div>
      <div class="relative z-[1] grid grid-cols-3 gap-2 mt-4">
        <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-3 py-3">
          <span class="text-[14px] font-[700] text-black dark:text-white block leading-tight">3 Tiers</span>
          <span class="text-[9px] text-black/50 dark:text-white/45 block mt-0.5">Core → Semantic → Component</span>
        </div>
        <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-3 py-3">
          <span class="text-[14px] font-[700] text-black dark:text-white block leading-tight">120+</span>
          <span class="text-[9px] text-black/50 dark:text-white/45 block mt-0.5">Tokens across color, type & space</span>
        </div>
        <div class="glass-1 rounded-[calc(var(--glass-radius)*0.7)] px-3 py-3">
          <span class="text-[14px] font-[700] text-black dark:text-white block leading-tight">Dark + Light</span>
          <span class="text-[9px] text-black/50 dark:text-white/45 block mt-0.5">Full theme support built-in</span>
        </div>
      </div>
    </div>
    <div class="col-span-2 glass-1 glass-specular rounded-[var(--glass-radius)] overflow-hidden md:hidden">
      <img
        src="/resources/images/gelui-design-token.png"
        alt="Design Token Architecture"
        class="w-full h-[200px] object-cover object-center"
      />
    </div>

    <!-- ════════════════════════════════════════
         Brand Colour Scheme
         ════════════════════════════════════════ -->
    <div class="col-span-2 row-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Brand Colour Scheme</h2>
        <p class="text-[11px] opacity-45 font-mono">{brand.length} brand colour{brand.length !== 1 ? "s" : ""} &middot; derived from logo</p>
      </div>

      <div class="flex flex-col gap-6">
        <!-- Hero: primary swatch + derived colours -->
        <div class="flex gap-3 max-[540px]:flex-col">
          <div
            class="relative flex-1 min-w-0 min-h-[120px] rounded-[var(--glass-radius)] border border-white/10 flex flex-col justify-end p-4"
            style={`background-color: ${baseHex}`}
          >
            <span class="text-[13px] font-semibold leading-tight" style={`color: ${textOnBg(baseHex)}`}>
              {primaryBrand.label}
            </span>
            <span class="text-[11px] font-mono mt-0.5" style={`color: ${textOnBgMuted(baseHex)}`}>
              {baseHex}
            </span>
          </div>

          <div class="grid grid-cols-2 gap-2 w-[42%] max-[540px]:w-full shrink-0">
            {derived.map((d) => (
              <div
                class="relative w-full aspect-[1.15/1] rounded-[var(--glass-radius-sm)] border border-white/10 flex flex-col justify-end p-2.5"
                style={`background-color: ${d.hex}`}
              >
                <span class="text-[11px] font-medium leading-tight" style={`color: ${textOnBg(d.hex)}`}>
                  {d.label}
                </span>
                <span class="text-[9px] font-mono mt-0.5" style={`color: ${textOnBgMuted(d.hex)}`}>
                  {d.hex}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Colour Scheme: all brand swatches -->
        <div class="flex flex-col gap-2">
          <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em]">Colour Scheme</span>
          <div class={`grid ${gridCols} gap-3 max-[540px]:grid-cols-2`}>
            {sortedBrand.map((b) => {
              const scale = getBrandScale(b.key);
              const hex = scale?.["500"] ?? b.hex;
              return (
                <div
                  class="relative w-full h-[72px] rounded-[var(--glass-radius-sm)] border border-white/10 flex flex-col justify-end p-3"
                  style={`background-color: ${hex}`}
                >
                  <span class="text-[12px] font-semibold leading-tight" style={`color: ${textOnBg(hex)}`}>
                    {ROLE_LABELS[b.role ?? ""] ?? b.label}
                  </span>
                  <span class="text-[10px] font-mono mt-0.5" style={`color: ${textOnBgMuted(hex)}`}>
                    {hex}
                  </span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Scales: detailed strips per colour -->
        <div class="flex flex-col gap-2">
          <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em]">Scales</span>
          <div class="flex flex-col gap-3">
            {sortedBrand.map((b) => {
              const scale = getBrandScale(b.key);
              const hex = scale?.["500"] ?? b.hex;
              return (
                <div class="flex flex-col gap-3 p-3 rounded-[var(--glass-radius-sm)] bg-white/[0.03] border border-[var(--glass-border)]">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 shrink-0 rounded-[10px] border border-white/10" style={`background-color: ${hex}`} />
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="text-[11.5px] font-[550]">{b.label}</span>
                        {b.role && (
                          <span class="text-[10px] font-mono opacity-50 px-1.5 py-0.5 rounded-[4px] bg-white/5">
                            {ROLE_LABELS[b.role] ?? b.role}
                          </span>
                        )}
                      </div>
                      <span class="text-[10px] font-mono opacity-40">{hex}</span>
                    </div>
                  </div>
                  {scale && (
                    <div class="flex gap-1">
                      {Object.entries(scale).map(([shade, color]) => (
                        <div class="flex flex-col items-center gap-0.5 flex-1 min-w-0">
                          <div
                            class="w-full h-5 rounded-[3px] border border-white/[0.04]"
                            style={`background-color: ${color}`}
                            title={`${shade}: ${color}`}
                          />
                          <span class="text-[8px] font-mono opacity-40">{shade}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              );
            })}
            <!-- Gray scale -->
            <div class="flex flex-col gap-3 p-3 rounded-[var(--glass-radius-sm)] bg-white/[0.03] border border-[var(--glass-border)]">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 shrink-0 rounded-[10px] border border-white/10" style={`background-color: ${colors.raw.gray[500]}`} />
                <div class="flex-1 min-w-0">
                  <span class="text-[11.5px] font-[550]">Gray</span>
                  <br />
                  <span class="text-[10px] font-mono opacity-40">{colors.raw.gray[500]}</span>
                </div>
              </div>
              <div class="flex gap-1">
                {Object.entries(colors.raw.gray).map(([shade, color]) => (
                  <div class="flex flex-col items-center gap-0.5 flex-1 min-w-0">
                    <div
                      class="w-full h-5 rounded-[3px] border border-white/[0.04]"
                      style={`background-color: ${color}`}
                      title={`${shade}: ${color}`}
                    />
                    <span class="text-[8px] font-mono opacity-40">{shade}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Colors: Semantic
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Colors: Semantic</h2>
        <p class="text-[11px] opacity-45 font-mono">Design decisions &mdash; remappable per version</p>
      </div>

      <div class="flex flex-col gap-1.5 rounded-[var(--glass-radius-sm)] overflow-hidden">
        {Object.entries(colors.semantic).map(([name, vals], idx) => {
          const lightHex = resolveSemanticHex(vals.light);
          const darkHexVal = resolveSemanticHex(vals.dark);
          return (
            <div class="flex w-full min-h-[64px]">
              <div
                class="flex-1 flex flex-col justify-end p-3 relative"
                style={`background-color: ${lightHex}`}
              >
                <span class="text-[12px] font-semibold leading-tight" style={`color: ${textOnBg(lightHex)}`}>
                  {name}
                </span>
                <span class="text-[9px] font-mono mt-0.5" style={`color: ${textOnBgMuted(lightHex)}`}>
                  {vals.light}
                </span>
              </div>
              <div
                class="flex-1 flex items-end justify-between p-3 relative"
                style={`background-color: ${darkHexVal}`}
              >
                <span class="text-[9px] font-mono" style={`color: ${textOnBgMuted(darkHexVal)}`}>
                  {vals.dark}
                </span>
                <span class="text-[28px] font-bold leading-none opacity-15" style={`color: ${textOnBg(darkHexVal)}`}>
                  {String(idx + 1).padStart(2, "0")}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Colors: Text
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Colors: Text</h2>
        <p class="text-[11px] opacity-45 font-mono">Opacity-based text hierarchy</p>
      </div>

      <div class="flex flex-col gap-4">
        {Object.entries(colors.text).map(([name, vals]) => (
          <div class="flex items-center gap-3">
            <div class="w-full max-w-[180px] py-1.5 px-3 rounded-[6px] glass-1">
              <span style={`color: ${vals.light}`} class="text-[13px] font-medium">
                Sample text
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <span class="text-[11.5px] font-[500]">{name}</span>
              <br />
              <span class="text-[10px] font-mono opacity-40">{vals.light}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Typography: Font Sizes
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Typography: Font Sizes</h2>
        <p class="text-[11px] opacity-45 font-mono">9 sizes from 10px to 36px</p>
      </div>

      <div class="flex flex-col gap-3">
        {Object.entries(typography.fontSize).map(([name, size]) => (
          <div class="flex items-baseline gap-4">
            <div class="w-[48px] shrink-0">
              <span class="text-[10px] font-mono opacity-40">{name}</span>
            </div>
            <span style={`font-size: ${size}; font-weight: 500; line-height: 1.3`}>
              The quick brown fox
            </span>
            <span class="text-[10px] font-mono opacity-40">{size}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Typography: Weights
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Typography: Weights</h2>
        <p class="text-[11px] opacity-45 font-mono">5 weights from 400 to 750</p>
      </div>

      <div class="flex flex-col gap-3">
        {Object.entries(typography.fontWeight).map(([name, weight]) => (
          <div class="flex items-baseline gap-4">
            <div class="w-[72px] shrink-0">
              <span class="text-[10px] font-mono opacity-40">{name}</span>
            </div>
            <span style={`font-weight: ${weight}; font-size: 17px; line-height: 1.3`}>
              The quick brown fox jumps
            </span>
            <span class="text-[10px] font-mono opacity-40">{weight}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Spacing
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Spacing</h2>
        <p class="text-[11px] opacity-45 font-mono">4px base unit</p>
      </div>

      <div class="flex flex-col gap-2.5">
        {Object.entries(spacing.raw).filter(([k]) => k !== "0").map(([step, value]) => (
          <div class="flex items-center gap-3">
            <div class="w-[36px] shrink-0">
              <span class="text-[10px] font-mono opacity-40">{step}</span>
            </div>
            <div
              class="h-4 rounded-[3px]"
              style={`width: calc(${value} * 2.5); opacity: 0.5; background-color: var(--accent, #3700FF)`}
            />
            <span class="text-[10px] font-mono opacity-40">{value}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Border Radii
         ════════════════════════════════════════ -->
    <div class="col-span-1 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Border Radii</h2>
        <p class="text-[11px] opacity-45 font-mono">Raw values + 3 presets</p>
      </div>

      <div class="flex flex-wrap gap-3">
        {Object.entries(radii.raw).slice(0, 8).map(([name, value]) => (
          <div class="flex flex-col items-center gap-1.5">
            <div
              class="w-12 h-12 border-2"
              style={`border-radius: ${value}; opacity: 0.4; border-color: var(--accent, #3700FF)`}
            />
            <span class="text-[10px] font-mono opacity-40">{value}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Radius Presets
         ════════════════════════════════════════ -->
    <div class="col-span-1 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Radius Presets</h2>
        <p class="text-[11px] opacity-45 font-mono">User-configurable</p>
      </div>

      <div class="flex flex-col gap-4">
        {radiiPresetEntries.map(([name, preset]) => (
          <div class="flex flex-col gap-1.5">
            <span class="text-[11.5px] font-[550]">{name}</span>
            <div class="flex gap-2">
              {Object.entries(preset).map(([key, val]) => (
                <div class="flex flex-col items-center gap-1">
                  <div
                    class="w-9 h-9 opacity-30"
                    style={`border-radius: ${val}; background-color: var(--accent, #3700FF)`}
                  />
                  <span class="text-[10px] font-mono opacity-40">{val}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Shadow Presets
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Shadow Presets</h2>
        <p class="text-[11px] opacity-45 font-mono">Flat, Soft, Elevated</p>
      </div>

      <div class="grid grid-cols-3 gap-4 max-[540px]:grid-cols-1">
        {shadowPresetEntries.map(([name, preset]) => (
          <div class="flex flex-col items-center gap-3">
            <div
              class="w-full h-20 rounded-[var(--glass-radius)] bg-[var(--glass-bg,rgba(255,255,255,0.06))]"
              style={`box-shadow: ${preset.glass}`}
            />
            <span class="text-[11.5px] font-[550]">{name}</span>
            <span class="text-[10px] font-mono opacity-40 break-all text-center">
              {preset.glass === "none" ? "none" : "multi-layer"}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Glass Levels
         ════════════════════════════════════════ -->
    <div class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Glass Levels</h2>
        <p class="text-[11px] opacity-45 font-mono">4 depth levels for glass morphism</p>
      </div>

      <div class="grid grid-cols-4 gap-3 max-[860px]:grid-cols-2 max-[540px]:grid-cols-2">
        {glassLevelEntries.map(([level, data]) => (
          <div class={`glass-${level} flex flex-col items-center justify-center gap-2 py-5 px-2 rounded-[var(--glass-radius-sm)]`}>
            <span class="text-[17px] font-[650]">{level}</span>
            <span class="text-[11.5px] opacity-55">{data.label}</span>
            <div class="flex flex-col items-center gap-0.5 mt-1">
              <span class="text-[10px] font-mono opacity-40">blur: {data.blur}px</span>
              <span class="text-[10px] font-mono opacity-40">sat: {data.saturate}</span>
              <span class="text-[10px] font-mono opacity-40">alpha: {data.bgAlpha}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Glass Types
         ════════════════════════════════════════ -->
    <div class="col-span-full relative overflow-hidden rounded-[var(--glass-radius)] p-5 border border-[var(--glass-border)]">
      <div class="flex flex-col gap-1 mb-5">
        <h2 class="text-[15px] font-[600]">Glass Types</h2>
        <p class="text-[11px] opacity-45 font-mono">5 distinct glass effect categories</p>
      </div>

      <!-- 3×2 grid of glass types -->
      <div class="grid grid-cols-3 gap-5 max-[540px]:grid-cols-1">
        <!-- 1. Transparent -->
        <div class="flex flex-col gap-3">
          <div class="glass-transparent rounded-[var(--glass-radius)] p-6 min-h-[120px] flex items-center justify-center">
            <span class="text-[13px] font-[550]">Transparent</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Transparent</span>
            <span class="text-[10px] opacity-40">No blur, no background. Border only &mdash; fully see-through.</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">glass-transparent</span>
          </div>
        </div>

        <!-- 2. Standard Glass -->
        <div class="flex flex-col gap-3">
          <div class="glass-1 glass-specular rounded-[var(--glass-radius)] p-6 min-h-[120px] flex items-center justify-center relative">
            <span class="text-[13px] font-[550] relative z-[1]">Standard Glass</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Standard Glass</span>
            <span class="text-[10px] opacity-40">Backdrop blur + semi-transparent background. 4 intensity levels (0&ndash;3).</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">glass-0 &middot; glass-1 &middot; glass-2 &middot; glass-3</span>
          </div>
        </div>

        <!-- 3. Gel Glass -->
        <div class="flex flex-col gap-3">
          <div class="gel-glass p-6 min-h-[120px] flex items-center justify-center relative">
            <div class="gel-glass-shine"></div>
            <span class="text-[13px] font-[550] relative z-[3]">Gel Glass</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Gel Glass</span>
            <span class="text-[10px] opacity-40">10-layer volumetric inset shadows + specular highlight. Physical depth.</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">gel-glass &middot; gel-glass-context-menu</span>
          </div>
        </div>

        <!-- 4. Glass on Glass -->
        <div class="flex flex-col gap-3">
          <div class="gel-glass-nav rounded-[var(--glass-radius)] p-4 min-h-[120px] flex items-center justify-center relative">
            <div class="glass-1 glass-specular rounded-[var(--glass-radius-sm)] px-5 py-3 relative z-[1]">
              <span class="text-[13px] font-[550] relative z-[1]">Glass on Glass</span>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Glass on Glass</span>
            <span class="text-[10px] opacity-40">Strong glass outer with lighter glass inner. Different transparency levels layered.</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">gel-glass-nav &rarr; glass-1 glass-specular</span>
          </div>
        </div>

        <!-- 5. Glass on Gel -->
        <div class="flex flex-col gap-3">
          <div class="gel-glass p-4 min-h-[120px] flex items-center justify-center relative">
            <div class="gel-glass-shine"></div>
            <div class="glass-1 glass-specular rounded-[var(--glass-radius-sm)] px-5 py-3 relative z-[3]">
              <span class="text-[13px] font-[550] relative z-[1]">Glass on Gel</span>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Glass on Gel</span>
            <span class="text-[10px] opacity-40">Volumetric gel outer with glass inner. Deepest compound layering effect.</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">gel-glass &rarr; glass-1 glass-specular</span>
          </div>
        </div>

        <!-- 6. Gel on Glass -->
        <div class="flex flex-col gap-3">
          <div class="glass-1 glass-specular rounded-[var(--glass-radius)] p-4 min-h-[120px] flex items-center justify-center relative">
            <div class="gel-glass rounded-[var(--glass-radius-sm)] px-5 py-3 relative z-[1]">
              <div class="gel-glass-shine"></div>
              <span class="text-[13px] font-[550] relative z-[3]">Gel on Glass</span>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-[11.5px] font-[550]">Gel on Glass</span>
            <span class="text-[10px] opacity-40">Standard glass outer with volumetric gel inner. Inverted compound layering.</span>
            <span class="text-[10px] font-mono opacity-35 mt-0.5">glass-1 glass-specular &rarr; gel-glass</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Motion
         ════════════════════════════════════════ -->
    <div class="col-span-1 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Motion</h2>
        <p class="text-[11px] opacity-45 font-mono">Duration + easing tokens</p>
      </div>

      <div class="flex flex-col gap-1 mb-4">
        <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em] mb-1">Duration</span>
        {Object.entries(motion.duration).map(([name, value]) => (
          <div class="flex items-center justify-between gap-4 py-1.5">
            <span class="text-[11.5px] font-mono font-[500]">{name}</span>
            <span class="text-[11.5px] font-mono opacity-40">{value}</span>
          </div>
        ))}
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em] mb-1">Easing</span>
        {Object.entries(motion.easing).map(([name, value]) => (
          <div class="flex items-center justify-between gap-4 py-1.5">
            <span class="text-[11.5px] font-mono font-[500]">{name}</span>
            <span class="text-[11.5px] font-mono opacity-40 text-right break-all">{value}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Breakpoints & Z-Index
         ════════════════════════════════════════ -->
    <div class="col-span-1 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="flex flex-col gap-1 mb-4">
        <h2 class="text-[15px] font-[600]">Breakpoints & Z-Index</h2>
        <p class="text-[11px] opacity-45 font-mono">Responsive + layering</p>
      </div>

      <div class="flex flex-col gap-1 mb-4">
        <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em] mb-1">Breakpoints</span>
        {Object.entries(breakpoints).map(([name, value]) => (
          <div class="flex items-center justify-between gap-4 py-1.5">
            <span class="text-[11.5px] font-mono font-[500]">{name}</span>
            <span class="text-[11.5px] font-mono opacity-40">{value}px</span>
          </div>
        ))}
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-[11.5px] font-[550] uppercase opacity-45 tracking-[0.04em] mb-1">Z-Index</span>
        {Object.entries(zIndex).map(([name, value]) => (
          <div class="flex items-center justify-between gap-4 py-1.5">
            <span class="text-[11.5px] font-mono font-[500]">{name}</span>
            <span class="text-[11.5px] font-mono opacity-40">{value}</span>
          </div>
        ))}
      </div>
    </div>

  </div>


</DSLayout>

