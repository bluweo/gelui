            </div>
            {easingEntries.map(([name, value], idx) => (
              <div
                class:list={[
                  "motion-row group relative px-3 py-3 cursor-pointer",
                  idx < easingEntries.length - 1 && "border-b border-black/[0.04] dark:border-white/[0.04]"
                ]}
              >
                <div class="flex items-center justify-between gap-3 mb-2">
                  <span class="text-[12px] font-[600] text-black/75 dark:text-white/70">{name}</span>
                  <span class="text-[10px] font-mono text-black/35 dark:text-white/30 text-right max-w-[180px] truncate" title={value}>{value}</span>
                </div>
                <!-- Animation track -->
                <div class="relative h-1.5 rounded-full bg-black/[0.06] dark:bg-white/[0.06] overflow-hidden">
                  <div
                    class="motion-dot absolute top-0 left-0 h-full w-3 rounded-full bg-black/30 dark:bg-white/40"
                    style={`transition-duration: 600ms; transition-timing-function: ${value};`}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <script>
        document.querySelectorAll('.motion-row').forEach(row => {
          const dot = row.querySelector('.motion-dot');
          if (!dot) return;
          let isRight = false;

