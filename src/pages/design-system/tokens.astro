---
import DSLayout from "@/components/layout/DSLayout.astro";
import TokenHero from "@/components/block/TokenHero.astro";
import { FontSizeWeightTable } from "@/components/block/FontSizeWeightTable";
import { BrandColorPreview } from "@/components/block/BrandColorPreview";
import { LiveTheming } from "@/components/block/LiveTheming";
import {
  typography,
  spacing,
  radii,
  shadows,
  glass,
  motion,
  breakpoints,
  zIndex,
} from "@/tokens";

/* ─── Pre-compute entries ─── */
const radiiPresetEntries = Object.entries(radii.presets) as Array<[string, Record<string, string>]>;
const shadowPresetEntries = Object.entries(shadows.presets) as Array<[string, Record<string, string>]>;
const glassLevelEntries = Object.entries(glass.levels) as Array<[string, { blur: number; saturate: number; bgAlpha: number; label: string }]>;
const spacingRawEntries = Object.entries(spacing.raw) as Array<[string, string]>;
const fontSizeEntries = Object.entries(typography.fontSize) as Array<[string, string]>;
const fontWeightEntries = Object.entries(typography.fontWeight) as Array<[string, number]>;
const durationEntries = Object.entries(motion.duration) as Array<[string, string]>;
const easingEntries = Object.entries(motion.easing) as Array<[string, string]>;
const breakpointEntries = Object.entries(breakpoints) as Array<[string, number]>;
const zIndexEntries = Object.entries(zIndex) as Array<[string, number]>;
const radiiRawEntries = Object.entries(radii.raw) as Array<[string, string]>;
---

<DSLayout
  title="Design Tokens — GelUI"
  description="Explore GelUI's 3-tier token architecture: Core primitives, Semantic mapping, and Component wiring. 120+ tokens across colors, typography, spacing, shadows, glass levels, and motion."
  keywords="design tokens, color tokens, typography tokens, spacing tokens, shadow presets, glass levels, CSS variables, theming, dark mode tokens"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <TokenHero />

    <BrandColorPreview client:load />

    <!-- ════════════════════════════════════════
         Typography: Font Families
         ════════════════════════════════════════ -->
    <div data-section="Font Families" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex items-start justify-between mb-6 pt-1 pl-1">
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Typography</span>
          <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1">Font Families</h2>
          <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">4 standard font roles — <strong class="font-[600] text-black/80 dark:text-white/70">Heading</strong>, <strong class="font-[600] text-black/80 dark:text-white/70">Body</strong>, <strong class="font-[600] text-black/80 dark:text-white/70">UI</strong>, <strong class="font-[600] text-black/80 dark:text-white/70">Mono</strong> — plus 2 optional slots for Data and Accent</p>
        </div>
        <div class="flex items-center gap-2 shrink-0 mt-1">
          <!-- Reset fonts button -->
          <button
            id="font-reset-trigger"
            class="text-[11px] font-[550] px-3 py-1.5 rounded-full bg-black/[0.04] dark:bg-white/[0.06] hover:bg-black/[0.08] dark:hover:bg-white/[0.12] border border-black/[0.06] dark:border-white/[0.08] transition-all duration-150 cursor-pointer text-black/50 dark:text-white/40 hover:text-black/70 dark:hover:text-white/60"
            title="Reset all fonts to defaults"
          >
            Reset
          </button>
          <!-- Settings icon — opens Font Picker modal -->
          <button
            id="font-picker-trigger"
            class="w-9 h-9 flex items-center justify-center rounded-full bg-black/[0.04] dark:bg-white/[0.06] hover:bg-black/[0.08] dark:hover:bg-white/[0.12] border border-black/[0.06] dark:border-white/[0.08] transition-all duration-150 cursor-pointer shrink-0"
            title="Change font family"
          >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
            <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </div>
      <script>
        function initFontFamiliesBlock() {
          // Reset all fonts to defaults
          document.getElementById('font-reset-trigger')?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('gelui:reset-fonts'));
          });
          // Main settings icon — opens roles view
          document.getElementById('font-picker-trigger')?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('gelui:open-font-picker'));
          });
          // Individual role settings — opens directly to browse view for that role
          document.querySelectorAll('.font-role-setting-btn').forEach((btn) => {
            btn.addEventListener('click', () => {
              const role = (btn as HTMLElement).dataset.role;
              window.dispatchEvent(new CustomEvent('gelui:open-font-picker', { detail: { role } }));
            });
          });
          // Sync preview text from font picker modal to font family block
          window.addEventListener('gelui:font-preview-text', (e) => {
            const text = (e as CustomEvent).detail?.text;
            if (text) {
              document.querySelectorAll('.font-sample-text').forEach((el) => {
                el.textContent = text;
              });
            }
          });
        }
        // Run on initial load
        initFontFamiliesBlock();
        // Re-run after View Transitions navigation
        document.addEventListener('astro:page-load', initFontFamiliesBlock);
      </script>

      <div class="flex flex-col gap-4 relative z-[1]">
        <!-- Heading -->
        <div class="p-5 rounded-[var(--glass-radius-sm)] bg-white/90 dark:bg-black/60 border border-black/[0.06] dark:border-white/[0.08]">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-[650] uppercase tracking-[0.04em] text-white dark:text-white px-2 py-0.5 rounded-full bg-black/80 dark:bg-white/20">Heading</span>
              <span class="text-[12px] font-[650] font-mono text-black/50 dark:text-white/40">--font-heading</span>
            </div>
            <button class="font-role-setting-btn w-7 h-7 flex items-center justify-center rounded-full hover:bg-black/[0.06] dark:hover:bg-white/[0.08] transition-colors duration-150 cursor-pointer" data-role="heading" title="Change heading font">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <p class="text-[11px] font-mono text-black/40 dark:text-white/35 mb-1">H1–H6, hero text, banners, titles</p>
          <p class="text-[11px] font-mono text-black/30 dark:text-white/25 mb-4">Google Sans, system-ui, sans-serif</p>
          <div class="flex flex-col gap-2">
            <p data-font-preview style="--font-preview: var(--font-heading); font-weight: 400;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
            <p data-font-preview style="--font-preview: var(--font-heading); font-weight: 700;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
          </div>
          <div class="flex gap-2 mt-3 flex-wrap">
            {[400, 500, 600, 700].map((w) => (
              <span data-font-preview style={`--font-preview: var(--font-heading); font-weight: ${w}`} class="text-[12px] font-mono text-black/70 dark:text-white/60 px-2.5 py-1 rounded-full border border-black/[0.08] dark:border-white/[0.1] bg-black/[0.03] dark:bg-white/[0.05]">{w}</span>
            ))}
          </div>
        </div>

        <!-- Body -->
        <div class="p-5 rounded-[var(--glass-radius-sm)] bg-white/90 dark:bg-black/60 border border-black/[0.06] dark:border-white/[0.08]">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-[650] uppercase tracking-[0.04em] text-white dark:text-white px-2 py-0.5 rounded-full bg-black/80 dark:bg-white/20">Body</span>
              <span class="text-[12px] font-[650] font-mono text-black/50 dark:text-white/40">--font-body</span>
            </div>
            <button class="font-role-setting-btn w-7 h-7 flex items-center justify-center rounded-full hover:bg-black/[0.06] dark:hover:bg-white/[0.08] transition-colors duration-150 cursor-pointer" data-role="body" title="Change body font">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <p class="text-[11px] font-mono text-black/40 dark:text-white/35 mb-1">Paragraphs, descriptions, content</p>
          <p class="text-[11px] font-mono text-black/30 dark:text-white/25 mb-4">Google Sans, system-ui, sans-serif</p>
          <div class="flex flex-col gap-2">
            <p data-font-preview style="--font-preview: var(--font-body); font-weight: 400;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
            <p data-font-preview style="--font-preview: var(--font-body); font-weight: 650;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
          </div>
          <div class="flex gap-2 mt-3 flex-wrap">
            {[400, 500, 550, 600, 650, 700, 750].map((w) => (
              <span data-font-preview style={`--font-preview: var(--font-body); font-weight: ${w}`} class="text-[12px] font-mono text-black/70 dark:text-white/60 px-2.5 py-1 rounded-full border border-black/[0.08] dark:border-white/[0.1] bg-black/[0.03] dark:bg-white/[0.05]">{w}</span>
            ))}
          </div>
        </div>

        <!-- UI -->
        <div class="p-5 rounded-[var(--glass-radius-sm)] bg-white/90 dark:bg-black/60 border border-black/[0.06] dark:border-white/[0.08]">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-[650] uppercase tracking-[0.04em] text-white dark:text-white px-2 py-0.5 rounded-full bg-black/80 dark:bg-white/20">UI</span>
              <span class="text-[12px] font-[650] font-mono text-black/50 dark:text-white/40">--font-ui</span>
            </div>
            <button class="font-role-setting-btn w-7 h-7 flex items-center justify-center rounded-full hover:bg-black/[0.06] dark:hover:bg-white/[0.08] transition-colors duration-150 cursor-pointer" data-role="ui" title="Change UI font">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <p class="text-[11px] font-mono text-black/40 dark:text-white/35 mb-1">Buttons, nav, labels, badges, forms</p>
          <p class="text-[11px] font-mono text-black/30 dark:text-white/25 mb-4">Linked to Body font</p>
          <div class="flex flex-col gap-2">
            <p data-font-preview style="--font-preview: var(--font-ui); font-weight: 400;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
            <p data-font-preview style="--font-preview: var(--font-ui); font-weight: 700;" class="text-[20px] text-black dark:text-white leading-tight font-sample-text">
              The quick brown fox jumps over the lazy dog
            </p>
          </div>
          <div class="flex gap-2 mt-3 flex-wrap">
            {[400, 500, 600, 700].map((w) => (
              <span data-font-preview style={`--font-preview: var(--font-ui); font-weight: ${w}`} class="text-[12px] font-mono text-black/70 dark:text-white/60 px-2.5 py-1 rounded-full border border-black/[0.08] dark:border-white/[0.1] bg-black/[0.03] dark:bg-white/[0.05]">{w}</span>
            ))}
          </div>
        </div>

        <!-- Mono -->
        <div class="p-5 rounded-[var(--glass-radius-sm)] bg-white/90 dark:bg-black/60 border border-black/[0.06] dark:border-white/[0.08]">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-[650] uppercase tracking-[0.04em] text-white dark:text-white px-2 py-0.5 rounded-full bg-black/80 dark:bg-white/20">Mono</span>
              <span class="text-[12px] font-[650] font-mono text-black/50 dark:text-white/40">--font-mono</span>
            </div>
            <button class="font-role-setting-btn w-7 h-7 flex items-center justify-center rounded-full hover:bg-black/[0.06] dark:hover:bg-white/[0.08] transition-colors duration-150 cursor-pointer" data-role="mono" title="Change mono font">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <p class="text-[11px] font-mono text-black/40 dark:text-white/35 mb-1">Code, tokens, technical data</p>
          <p class="text-[11px] font-mono text-black/30 dark:text-white/25 mb-4">SF Mono, SFMono-Regular, ui-monospace, Menlo, monospace</p>
          <div class="flex flex-col gap-2">
            <p data-font-preview style="--font-preview: var(--font-mono); font-weight: 400;" class="text-[18px] text-black dark:text-white leading-tight font-sample-text">
              const token = "design-system";
            </p>
            <p data-font-preview style="--font-preview: var(--font-mono); font-weight: 600;" class="text-[18px] text-black dark:text-white leading-tight font-sample-text">
              const token = "design-system";
            </p>
          </div>
          <div class="flex gap-2 mt-3 flex-wrap">
            {[400, 600].map((w) => (
              <span data-font-preview style={`--font-preview: var(--font-mono); font-weight: ${w}`} class="text-[12px] font-mono text-black/70 dark:text-white/60 px-2.5 py-1 rounded-full border border-black/[0.08] dark:border-white/[0.1] bg-black/[0.03] dark:bg-white/[0.05]">{w}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Typography: Sizes & Weights
         ════════════════════════════════════════ -->
    <div data-section="Sizes & Weights" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Typography</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1">Sizes & Weights</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">9 sizes and 5 weights — preview in any font role</p>
      </div>

      <div class="relative z-[1]">
        <FontSizeWeightTable
          client:load
          fontSizes={fontSizeEntries}
          fontWeights={fontWeightEntries}
        />
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Spacing
         ════════════════════════════════════════ -->
    <div data-section="Spacing" class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5">
      <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />
      <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">Layout</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1">Spacing</h2>
        <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">4px base unit system for consistent rhythm</p>
      </div>

      <!-- Semantic spacing groups -->
      <div class="relative z-[1]">
        <div class="grid grid-cols-4 gap-3 mb-5 max-[860px]:grid-cols-2">
          {[
            { label: "XS", name: "componentXs", step: "1", value: "0.25rem", px: "4px", desc: "Badge padding" },
            { label: "SM", name: "componentSm", step: "2", value: "0.5rem", px: "8px", desc: "Compact elements" },
            { label: "MD", name: "componentMd", step: "3", value: "0.75rem", px: "12px", desc: "Standard internal" },
            { label: "LG", name: "componentLg", step: "4", value: "1rem", px: "16px", desc: "Generous internal" },
          ].map((s) => (
            <div class="p-4 rounded-[var(--glass-radius-sm)] bg-white/80 dark:bg-black/50 border border-black/[0.06] dark:border-white/[0.08] flex flex-col items-center gap-2">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-white px-2 py-0.5 rounded-full bg-black/70 dark:bg-white/20">{s.label}</span>
              <div class="flex items-center justify-center w-full h-10">
                <div class="rounded-[3px]" style={`width: ${s.px}; height: ${s.px}; min-width: 4px; min-height: 4px; background-color: var(--token-preview-fill);`} />
              </div>
              <span class="text-[13px] font-mono font-[600] text-black/80 dark:text-white/75">{s.px}</span>
              <span class="text-[10px] text-black/40 dark:text-white/35 text-center">{s.desc}</span>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-4 gap-3 mb-5 max-[860px]:grid-cols-2">
          {[
            { label: "Section", step: "5", value: "1.25rem", px: "20px", desc: "Between sections" },
