        <div>
          <div class="rounded-[var(--glass-radius-sm)] overflow-hidden bg-white/60 dark:bg-black/30">
            <div class="flex items-center justify-between px-3 py-2 bg-black/[0.04] dark:bg-white/[0.06] border-b border-black/[0.06] dark:border-white/[0.06]">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/45 dark:text-white/40">Token</span>
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/45 dark:text-white/40">Min Width</span>
            </div>
            {breakpointEntries.map(([name, value], idx) => (
              <div class:list={["flex items-center justify-between gap-3 px-3 py-2.5", idx < breakpointEntries.length - 1 && "border-b border-black/[0.04] dark:border-white/[0.04]"]}>
                <span class="text-[12px] font-[600] text-black/75 dark:text-white/70">{name}</span>
                <span class="text-[11px] font-mono px-2 py-0.5 rounded-full bg-black/[0.05] dark:bg-white/[0.07] text-black/50 dark:text-white/40 tabular-nums">{value}px</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Z-Index -->
        <div>
          <div class="rounded-[var(--glass-radius-sm)] overflow-hidden bg-white/60 dark:bg-black/30">
            <div class="flex items-center justify-between px-3 py-2 bg-black/[0.04] dark:bg-white/[0.06] border-b border-black/[0.06] dark:border-white/[0.06]">
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/45 dark:text-white/40">Layer</span>
              <span class="text-[10px] font-[650] uppercase tracking-[0.06em] text-black/45 dark:text-white/40">Value</span>
            </div>
            {zIndexEntries.map(([name, value], idx) => (
              <div class:list={["flex items-center justify-between gap-3 px-3 py-2.5", idx < zIndexEntries.length - 1 && "border-b border-black/[0.04] dark:border-white/[0.04]"]}>
                <span class="text-[12px] font-[600] text-black/75 dark:text-white/70">{name}</span>
                <div class="flex items-center gap-2">
                  <div class="h-1.5 rounded-full bg-black/10 dark:bg-white/10" style={`width: ${Math.min(Math.max(value / 15, 4), 60)}px;`} />
                  <span class="text-[11px] font-mono text-black/40 dark:text-white/35 tabular-nums">{value}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════
         Live Theming
         ════════════════════════════════════════ -->
    <div data-section="Live Theming" class="col-span-2 relative overflow-hidden rounded-[var(--glass-radius)] p-5 border contrast-border">
      <div class="flex flex-col gap-1 mb-6 pt-1 pl-1">
        <span class="text-[10px] font-[650] uppercase tracking-[0.1em] contrast-muted mb-1">Runtime</span>
        <h2 class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] contrast-text mb-1" style="font-family: var(--font-heading)">Live Theming</h2>
        <p class="text-[13px] leading-[1.6] contrast-muted">How Appearance settings cascade to every component via CSS variables</p>
      </div>
      <LiveTheming client:load />
    </div>

  </div>


</DSLayout>

