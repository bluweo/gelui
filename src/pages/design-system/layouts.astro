---
import DSLayout from "@/layouts/DSLayout.astro";
---

<DSLayout
  title="Layouts — GelUI Design System"
  description="Page-level composition in GelUI: responsive grids, shells, bento layouts, and page templates. Build adaptive glassmorphism layouts that work across all viewports."
  keywords="page layouts, responsive grids, bento layouts, page templates, glass layouts, responsive design, viewport breakpoints"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">

    <div class="col-span-full mb-2">
      <h1 class="text-[24px] font-[650] tracking-[-0.02em] leading-tight">Layouts</h1>
      <p class="text-[13px] mt-1 opacity-50">Page-level composition: grids, responsive shells, bento layouts, and page templates.</p>
    </div>

    <div class="col-span-full glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-8 flex flex-col items-center justify-center min-h-[280px] gap-4">
      <span class="text-[48px] font-[650] opacity-10">L6</span>
      <span class="text-[15px] font-[550] opacity-60">Coming in Phase 5</span>
      <p class="text-[12px] opacity-35 max-w-[400px] text-center font-mono">
        Layout primitives (BentoGrid, PageShell, SplitView, ResponsiveStack) will be documented here with responsive breakpoint demos.
      </p>
    </div>

  </div>
</DSLayout>
