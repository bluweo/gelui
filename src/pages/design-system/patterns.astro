---
import DSLayout from "@/components/layout/DSLayout.astro";
import PatternsHero from "@/components/block/PatternsHero.astro";

/* ─── Pattern Categories ─── */
const sections = [
  {
    id: "authentication",
    label: "Authentication",
    title: "Authentication Flows",
    description: "Complete auth patterns covering login, registration, password recovery, and verification — ready to integrate with any auth provider.",
    items: ["Login", "Register", "Forgot Password", "OTP Verification", "Social Auth"],
  },
  {
    id: "dashboard",
    label: "Dashboard",
    title: "Dashboard Layouts",
    description: "Data-rich dashboard patterns with KPI cards, chart compositions, activity feeds, and overview layouts for analytics interfaces.",
    items: ["Analytics", "KPI Cards", "Chart Layout", "Activity Feed", "Overview"],
  },
  {
    id: "settings",
    label: "Settings",
    title: "Settings Pages",
    description: "User-facing settings patterns for profile management, preferences, notification controls, security configuration, and billing.",
    items: ["Profile", "Preferences", "Notifications", "Security", "Billing"],
  },
  {
    id: "data-management",
    label: "Data Management",
    title: "Data Management",
    description: "CRUD interfaces, filtering and sorting controls, bulk operations, import/export flows, and search patterns for managing collections of data.",
    items: ["CRUD", "Filters & Sort", "Bulk Actions", "Import/Export", "Search"],
  },
  {
    id: "onboarding",
    label: "Onboarding",
    title: "Onboarding Flows",
    description: "First-run experiences including welcome screens, feature tours, step-by-step setup wizards, and getting started guides.",
    items: ["Welcome", "Feature Tour", "Setup Wizard", "Getting Started"],
  },
  {
    id: "empty-states",
    label: "Empty States",
    title: "Empty States",
    description: "Contextual empty state patterns for no-data scenarios, error pages, offline indicators, maintenance screens, and permission denials.",
    items: ["No Data", "Error", "Offline", "Maintenance", "Permission Denied"],
  },
];
---

<DSLayout
  title="Patterns — GelUI Design System"
  description="Recurring UI patterns and flows that solve common design challenges. Authentication, dashboards, settings, data management, onboarding, and empty states — built from Gel UI components."
  keywords="UI patterns, authentication, dashboard, settings, data management, onboarding, empty states, design patterns, gel patterns"
>
  <div class="w-full grid grid-cols-4 gap-5 max-[860px]:grid-cols-2 max-[860px]:gap-4 max-[540px]:grid-cols-1 max-[540px]:gap-3">

    <PatternsHero />

    {sections.map((section) => (
      <div
        data-section={section.label}
        id={section.id}
        class="col-span-2 glass-1 glass-specular relative overflow-hidden rounded-[var(--glass-radius)] p-5"
      >
        <div class="absolute inset-0 pointer-events-none ds-card-frost" style="height: 160px;" />

        <div class="relative flex flex-col gap-1 mb-6 pt-1 pl-1">
          <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-1">
            {section.label}
          </span>
          <h2
            class="text-[24px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-1"
            style="font-family: var(--font-heading)"
          >
            {section.title}
          </h2>
          <p class="text-[13px] leading-[1.6] text-black/60 dark:text-white/55">
            {section.description}
          </p>
        </div>

        <!-- Items table -->
        <div class="relative rounded-[var(--glass-radius-sm)] overflow-hidden bg-white dark:bg-[#1a1a1a]">
          {section.items.map((item, i) => (
            <div
              class:list={[
                "flex items-center justify-between px-4 py-3",
                i < section.items.length - 1 && "border-b border-black/[0.06] dark:border-white/[0.06]",
              ]}
            >
              <span class="text-[13px] font-[550] text-black/70 dark:text-white/60">
                {item}
              </span>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-[650] uppercase tracking-[0.04em] bg-amber-500/10 text-amber-600 dark:bg-amber-400/10 dark:text-amber-400">
                Coming Soon
              </span>
            </div>
          ))}
        </div>
      </div>
    ))}

  </div>
</DSLayout>
