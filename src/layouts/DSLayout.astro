---
import BaseLayout from "./BaseLayout.astro";
import { DSShell } from "@/islands/DSShell";

interface Props {
  title?: string;
}

const { title = "GelUI Design System" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title}>
  <DSShell client:load currentPath={currentPath}>
    <slot />
  </DSShell>
</BaseLayout>
