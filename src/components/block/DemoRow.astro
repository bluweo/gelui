---
interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<div class="flex items-center gap-3">
  {label && (
    <span class="text-xs font-medium min-w-[80px] shrink-0" style="color: var(--text-tertiary);">
      {label}
    </span>
  )}
  <div class="flex items-center gap-2 flex-wrap">
    <slot />
  </div>
</div>
