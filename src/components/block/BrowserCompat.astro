---
/**
 * BrowserCompat — Browser compatibility with logo cards + feature support table
 * Usage: <BrowserCompat />
 */
import DSCard from "../card/DSCard.astro";

const BROWSERS = [
  { name: "Chrome", version: "111+", logo: "/logos/browsers/chrome.svg" },
  { name: "Edge", version: "111+", logo: "/logos/browsers/edge.svg" },
  { name: "Safari", version: "18+", logo: "/logos/browsers/safari.svg" },
  { name: "Firefox", version: "128+", logo: "/logos/browsers/firefox.svg" },
  { name: "Samsung", version: "28+", logo: "/logos/browsers/samsung.svg" },
  { name: "Opera", version: "98+", logo: "/logos/browsers/opera.svg" },
];

const FEATURES = [
  { feature: "backdrop-filter: blur()", chrome: "76+", firefox: "103+", safari: "9+", supported: true },
  { feature: "CSS color-mix()", chrome: "111+", firefox: "113+", safari: "16.2+", supported: true },
  { feature: "CSS nesting", chrome: "113+", firefox: "117+", safari: "16.6+", supported: true },
  { feature: "oklch() / oklab()", chrome: "111+", firefox: "113+", safari: "15.4+", supported: true },
  { feature: "View Transitions (SPA)", chrome: "111+", firefox: "—", safari: "18+", supported: false },
  { feature: "View Transitions (MPA)", chrome: "126+", firefox: "—", safari: "18.2+", supported: false },
];
---

<DSCard span={4} frost={true} frostHeight="220px">
  <div class="grid grid-cols-[1fr_2fr] gap-8 max-[860px]:grid-cols-1 max-[860px]:gap-6">

    {/* ── Left: Title + description ── */}
    <div class="flex flex-col pt-4 pl-3">
      <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-2">Compatibility</span>
      <h2 class="text-[28px] max-[540px]:text-[22px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-3">
        Browser Support
      </h2>
      <p class="text-[13px] leading-[1.65] text-black/55 dark:text-white/55 max-w-[300px] mb-5">
        Every glass and gel effect works across all modern browsers. View Transitions degrade gracefully where unsupported.
      </p>

      {/* Browser cards — 2x3 grid */}
      <div class="grid grid-cols-3 gap-2 max-[860px]:grid-cols-6 max-[640px]:grid-cols-3">
        {BROWSERS.map((browser) => (
          <div class="flex flex-col items-center gap-2.5 py-5 px-3 rounded-[var(--glass-radius-sm)] bg-white dark:bg-[#1a1a24] border border-gray-100 dark:border-white/[0.08] transition-all duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
            <img
              src={browser.logo}
              alt={browser.name}
              class="w-12 h-12 object-contain"
              loading="lazy"
            />
            <span class="text-[13px] leading-tight">
              <span class="font-[600] text-black dark:text-white">{browser.name}</span>
              <span class="font-[500] text-black/50 dark:text-white/45 ml-1">{browser.version}</span>
            </span>
          </div>
        ))}
      </div>
    </div>

    {/* ── Right: Feature support table ── */}
    <div class="flex flex-col" style="font-family: 'Google Sans', sans-serif;">
      {/* Table header */}
      <div class="flex items-center gap-0 rounded-t-[var(--glass-radius-sm)] bg-gray-50 dark:bg-white/[0.04] border border-gray-100 dark:border-white/[0.08] border-b-0">
        <div class="flex-1 px-4 py-3">
          <span class="text-[11px] font-[650] uppercase tracking-[0.05em] text-black/40 dark:text-white/35">Feature</span>
        </div>
        <div class="w-[90px] px-3 py-3 text-center">
          <span class="text-[11px] font-[650] uppercase tracking-[0.05em] text-black/40 dark:text-white/35">Chrome</span>
        </div>
        <div class="w-[90px] px-3 py-3 text-center">
          <span class="text-[11px] font-[650] uppercase tracking-[0.05em] text-black/40 dark:text-white/35">Firefox</span>
        </div>
        <div class="w-[90px] px-3 py-3 text-center">
          <span class="text-[11px] font-[650] uppercase tracking-[0.05em] text-black/40 dark:text-white/35">Safari</span>
        </div>
        <div class="w-[70px] px-3 py-3 text-center">
          <span class="text-[11px] font-[650] uppercase tracking-[0.05em] text-black/40 dark:text-white/35">Status</span>
        </div>
      </div>

      {/* Table rows */}
      {FEATURES.map((row, i) => (
        <div class:list={[
          "flex items-center gap-0 border-x border-b border-gray-100 dark:border-white/[0.08] bg-white dark:bg-[#1a1a24] transition-colors duration-150 hover:bg-gray-50 dark:hover:bg-white/[0.03]",
          i === FEATURES.length - 1 && "rounded-b-[var(--glass-radius-sm)]",
        ]}>
          <div class="flex-1 px-4 py-3.5">
            <code class="text-[12px] font-[500] font-mono text-black/70 dark:text-white/65">{row.feature}</code>
          </div>
          <div class="w-[90px] px-3 py-3.5 text-center">
            <span class="text-[12px] font-[600] text-black/60 dark:text-white/50">{row.chrome}</span>
          </div>
          <div class="w-[90px] px-3 py-3.5 text-center">
            <span class:list={[
              "text-[12px] font-[600]",
              row.firefox === "—" ? "text-red-400/60 dark:text-red-400/40" : "text-black/60 dark:text-white/50",
            ]}>{row.firefox}</span>
          </div>
          <div class="w-[90px] px-3 py-3.5 text-center">
            <span class="text-[12px] font-[600] text-black/60 dark:text-white/50">{row.safari}</span>
          </div>
          <div class="w-[70px] px-3 py-3.5 text-center">
            {row.supported ? (
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-500/10 text-green-500 text-[11px]">✓</span>
            ) : (
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-500/10 text-amber-500 text-[11px]">~</span>
            )}
          </div>
        </div>
      ))}

      {/* Warning callout */}
      <div class="mt-4 flex items-start gap-2.5 px-4 py-3 rounded-[var(--glass-radius-sm)] bg-amber-500/[0.06] dark:bg-amber-500/[0.08] border border-amber-500/[0.12]">
        <span class="text-[13px] shrink-0 mt-0.5">⚠️</span>
        <span class="text-[11.5px] text-black/55 dark:text-white/50 leading-[1.6]">Firefox lacks View Transitions API support. All glass effects degrade gracefully — backdrop-filter and color-mix are supported across all modern browsers.</span>
      </div>
    </div>

  </div>
</DSCard>
