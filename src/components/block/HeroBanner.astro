---
/**
 * HeroBanner — Gel UI marketing hero block
 * Usage: <HeroBanner />
 */
---

<div class="relative overflow-hidden rounded-[var(--glass-radius)] p-8 max-[540px]:p-6 flex flex-col justify-start bg-white dark:bg-[#1a1a24]">
  <p class="text-[11px] font-[650] uppercase tracking-[0.08em] text-gray-400 dark:text-gray-500 mb-3">Design System</p>
  <h1 class="type-h1 mb-3 text-black dark:text-white">
    Gel UI
  </h1>
  <p class="text-[22px] max-[540px]:text-[18px] font-[600] tracking-[-0.02em] leading-[1.25] text-gray-500 dark:text-gray-400 mb-5">
    Interfaces that feel<br />alive under your fingers.
  </p>
  <p class="text-[13px] leading-[1.7] text-gray-500 dark:text-gray-400 max-w-[520px]">
    A glassmorphism-first framework with volumetric gel surfaces, 10-layer shadow depth, adaptive contrast detection, and real-time appearance tuning. Every surface blurs, refracts, and breathes.
  </p>
  <div class="flex items-center gap-3 mt-6 flex-wrap">
    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--glass-radius-sm)] border border-black/10 dark:border-white/15 text-[13px] font-[600] text-white dark:text-black bg-black/80 dark:bg-white/90">
      <img src="/logos/tech/astro-white.svg" alt="Astro" width="20" height="20" class="shrink-0 dark:hidden" />
      <img src="/logos/tech/astro.svg" alt="Astro" width="20" height="20" class="shrink-0 hidden dark:block" />
      Astro 5
    </span>
    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--glass-radius-sm)] border border-black/10 dark:border-white/15 text-[13px] font-[600] text-white dark:text-black bg-black/80 dark:bg-white/90">
      <img src="/logos/tech/react-white.svg" alt="React" width="20" height="20" class="shrink-0 dark:hidden" />
      <img src="/logos/tech/react.svg" alt="React" width="20" height="20" class="shrink-0 hidden dark:block" />
      React 19
    </span>
    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--glass-radius-sm)] border border-black/10 dark:border-white/15 text-[13px] font-[600] text-white dark:text-black bg-black/80 dark:bg-white/90">
      <img src="/logos/tech/tailwindcss-white.svg" alt="Tailwind CSS" width="20" height="20" class="shrink-0 dark:hidden" />
      <img src="/logos/tech/tailwindcss.svg" alt="Tailwind CSS" width="20" height="20" class="shrink-0 hidden dark:block" />
      Tailwind v4
    </span>
  </div>
</div>
