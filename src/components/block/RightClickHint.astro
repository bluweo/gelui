---
/**
 * RightClickHint — Floating radar-pulse dot with hint text
 * Tells users they can right-click to change background & appearance.
 * Uses contrast detection for text color.
 * Usage: <RightClickHint />
 */
---

<div id="right-click-hint" class="fixed right-[12%] top-[35%] z-50 flex flex-col items-center gap-3 pointer-events-none max-[860px]:right-[3%] max-[640px]:hidden" style="opacity:0; transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
  <!-- Radar pulse dot -->
  <div class="relative w-5 h-5">
    <span id="rch-ring1" class="absolute inset-0 rounded-full animate-[radarPulse_2.4s_ease-out_infinite]" style="background: rgba(255,255,255,0.3);"></span>
    <span id="rch-ring2" class="absolute inset-0 rounded-full animate-[radarPulse_2.4s_ease-out_0.8s_infinite]" style="background: rgba(255,255,255,0.25);"></span>
    <span id="rch-ring3" class="absolute inset-0 rounded-full animate-[radarPulse_2.4s_ease-out_1.6s_infinite]" style="background: rgba(255,255,255,0.2);"></span>
    <span id="rch-dot" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full animate-[dotGlow_2.4s_ease-in-out_infinite]" style="background: #ffffff; box-shadow: 0 0 12px rgba(255,255,255,0.6), 0 0 4px rgba(255,255,255,0.9);"></span>
  </div>

  <!-- Hint text -->
  <div class="flex flex-col items-center gap-1 animate-[floatY_3s_ease-in-out_infinite]">
    <p id="rch-title" class="text-[11px] font-[600] drop-shadow-[0_1px_6px_rgba(0,0,0,0.4)] whitespace-nowrap" style="color: #ffffff;">
      Right-click anywhere
    </p>
    <p id="rch-sub" class="text-[10px] font-[400] drop-shadow-[0_1px_4px_rgba(0,0,0,0.3)] whitespace-nowrap" style="color: rgba(255,255,255,0.7);">
      Change background & appearance
    </p>
  </div>
</div>

<style is:global>
  @keyframes radarPulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(4);
      opacity: 0;
    }
  }

  @keyframes dotGlow {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  @keyframes floatY {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
</style>

<script>
  (function() {
    let hintDismissed = false;
    const hint = document.getElementById('right-click-hint');
    if (!hint) return;

    const ring1 = document.getElementById('rch-ring1');
    const ring2 = document.getElementById('rch-ring2');
    const ring3 = document.getElementById('rch-ring3');
    const dot = document.getElementById('rch-dot');
    const title = document.getElementById('rch-title');
    const sub = document.getElementById('rch-sub');

    // Update colors based on contrast
    function updateContrast() {
      const main = document.querySelector('main[data-contrast]');
      const contrast = main?.getAttribute('data-contrast') || 'dark';
      const isDark = contrast === 'dark';

      const color = isDark ? '255,255,255' : '0,0,0';
      const solid = isDark ? '#ffffff' : '#000000';

      if (ring1) ring1.style.background = `rgba(${color},0.3)`;
      if (ring2) ring2.style.background = `rgba(${color},0.25)`;
      if (ring3) ring3.style.background = `rgba(${color},0.2)`;
      if (dot) {
        dot.style.background = solid;
        dot.style.boxShadow = `0 0 12px rgba(${color},0.6), 0 0 4px rgba(${color},0.9)`;
      }
      if (title) {
        title.style.color = solid;
        title.style.filter = isDark
          ? 'drop-shadow(0 1px 6px rgba(0,0,0,0.4))'
          : 'drop-shadow(0 1px 6px rgba(255,255,255,0.4))';
      }
      if (sub) {
        sub.style.color = `rgba(${color},0.7)`;
        sub.style.filter = isDark
          ? 'drop-shadow(0 1px 4px rgba(0,0,0,0.3))'
          : 'drop-shadow(0 1px 4px rgba(255,255,255,0.3))';
      }
    }

    // Watch for contrast changes on <main>
    const observer = new MutationObserver(updateContrast);
    const main = document.querySelector('main[data-contrast]');
    if (main) {
      observer.observe(main, { attributes: true, attributeFilter: ['data-contrast'] });
    }
    // Initial check
    updateContrast();

    // Fade in on load after a short delay
    setTimeout(() => {
      if (!hintDismissed && window.scrollY <= 100) {
        hint.style.opacity = '1';
      }
    }, 800);

    // Permanently dismiss when user right-clicks
    function dismissHint() {
      hintDismissed = true;
      hint.style.opacity = '0';
      hint.style.transform = 'translateY(-10px)';
      document.removeEventListener('contextmenu', dismissHint);
      window.removeEventListener('scroll', handleScroll);
      observer.disconnect();
    }

    // Show/hide based on scroll position
    function handleScroll() {
      if (hintDismissed) return;
      if (window.scrollY > 100) {
        hint.style.opacity = '0';
        hint.style.transform = 'translateY(-10px)';
      } else {
        hint.style.opacity = '1';
        hint.style.transform = 'translateY(0)';
      }
    }

    document.addEventListener('contextmenu', dismissHint);
    window.addEventListener('scroll', handleScroll, { passive: true });
  })();
</script>
