---
import BaseLayout from "./BaseLayout.astro";
import { DSShell } from "@/components/layout/DSShell";
import { BackToTop } from "@/primitives/navigation/BackToTop";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const { title = "GelUI Design System", description, keywords } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <DSShell client:load currentPath={currentPath}>
    <slot />
  </DSShell>
  <BackToTop client:load />
</BaseLayout>
