---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/plus-jakarta-sans";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title = "GelUI",
  description = "A glassmorphism-first design system with volumetric gel surfaces, adaptive contrast, and real-time appearance tuning.",
  keywords = "design system, glassmorphism, UI framework, glass UI, gel UI, Astro, React, Tailwind CSS, dark mode, adaptive contrast",
  ogImage = "/resources/images/gelui-og.png",
  ogType = "website",
  canonicalUrl,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? "https://gelui.bluweo.com";
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, siteUrl).toString();
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Bluweo" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logos/uigel-logo.svg" />
    <link rel="apple-touch-icon" href="/logos/uigel-logo.svg" />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="GelUI Design System" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "GelUI Design System",
      "url": siteUrl,
      "description": description,
      "creator": {
        "@type": "Organization",
        "name": "Bluweo",
        "url": "https://bluweo.com"
      }
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Blocking script: restore theme + fonts from localStorage before paint to prevent FOUC -->
    <script is:inline>
    (function() {
      // Restore theme FIRST (enables CSS [data-theme="dark"] variables before React hydrates)
      try {
        var appearance = JSON.parse(localStorage.getItem("gelui-appearance") || "{}");
        if (appearance.theme === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      } catch(e) {}

      // Restore fonts
      try {
        var stored = JSON.parse(localStorage.getItem("gelui-appearance") || "{}");
        var fonts = stored.fonts;
        if (!fonts) return;
        var rs = document.documentElement.style;
        var SAME = "SAME_AS_BODY";
        var bodyFont = fonts.body || "Google Sans";
        var bodyStack = "'" + bodyFont + "', 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif";

        rs.setProperty("--font-sans", bodyStack);
        rs.setProperty("--font-body", bodyStack);
        rs.setProperty("--font-heading", fonts.heading === SAME ? bodyStack : "'" + (fonts.heading || bodyFont) + "', " + bodyStack);
        rs.setProperty("--font-ui", fonts.ui === SAME ? bodyStack : "'" + (fonts.ui || bodyFont) + "', " + bodyStack);

        if (fonts.mono && fonts.mono !== "System Default") {
          rs.setProperty("--font-mono", "'" + fonts.mono + "', ui-monospace, monospace");
        }
        if (fonts.data) {
          rs.setProperty("--font-data", "'" + fonts.data + "', " + bodyStack);
        }
        if (fonts.accent) {
          rs.setProperty("--font-accent", "'" + fonts.accent + "', " + bodyStack);
        }

        // Also load Google Fonts that aren't the default
        var toLoad = [bodyFont, fonts.heading, fonts.ui, fonts.mono, fonts.data, fonts.accent];
        toLoad.forEach(function(f) {
          if (!f || f === "Plus Jakarta Sans" || f === "Google Sans" || f === "System Default" || f === SAME) return;
          var id = "google-font-" + f.replace(/\s+/g, "-").toLowerCase();
          if (!document.getElementById(id)) {
            var link = document.createElement("link");
            link.id = id;
            link.rel = "stylesheet";
            link.href = "https://fonts.googleapis.com/css2?family=" + encodeURIComponent(f) + ":wght@400;500;600;700&display=swap";
            document.head.appendChild(link);
          }
        });
      } catch(e) {}

      // Restore type presets CSS variables
      try {
        var typePresets = JSON.parse(localStorage.getItem("gelui-type-presets") || "[]");
        var varMap = {"Display":"display","H1":"h1","H2":"h2","H3":"h3","H4":"h4","H5":"h5","H6":"h6","Body":"body","Body Sm":"body-sm","Caption":"caption","Overline":"overline","Label":"label","Code":"code","Code Sm":"code-sm","Link":"link"};
        var rs = document.documentElement.style;
        typePresets.forEach(function(p) {
          var key = varMap[p.name];
          if (!key) return;
          if (p.size) rs.setProperty("--type-" + key + "-size", p.size);
          if (p.weight) rs.setProperty("--type-" + key + "-weight", String(p.weight));
          if (p.lh) rs.setProperty("--type-" + key + "-lh", p.lh);
          if (p.ls) rs.setProperty("--type-" + key + "-ls", p.ls);
        });
      } catch(e) {}
    })();
    </script>
  </head>
  <body class="font-sans min-h-screen overflow-x-hidden leading-normal" style="color: var(--text-primary);">
    <slot />
  </body>
</html>
