---
/**
 * RightClickHint — Floating radar-pulse dot with hint text
 * Tells users they can right-click to change background & appearance.
 * Auto-hides after 8 seconds. Click to dismiss.
 * Usage: <RightClickHint />
 */
---

<div id="right-click-hint" class="fixed right-[5%] top-[45%] z-50 flex flex-col items-center gap-3 pointer-events-none max-[860px]:right-[3%] max-[640px]:hidden" style="opacity:0; transition: opacity 0.5s ease-out, transform 0.5s ease-out;">
  <!-- Radar pulse dot -->
  <div class="relative w-5 h-5">
    <!-- Outer pulse ring 1 -->
    <span class="absolute inset-0 rounded-full bg-white/30 dark:bg-white/20 animate-[radarPulse_2.4s_ease-out_infinite]"></span>
    <!-- Outer pulse ring 2 (delayed) -->
    <span class="absolute inset-0 rounded-full bg-white/25 dark:bg-white/15 animate-[radarPulse_2.4s_ease-out_0.8s_infinite]"></span>
    <!-- Outer pulse ring 3 (delayed more) -->
    <span class="absolute inset-0 rounded-full bg-white/20 dark:bg-white/10 animate-[radarPulse_2.4s_ease-out_1.6s_infinite]"></span>
    <!-- Core dot -->
    <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-white dark:bg-white shadow-[0_0_12px_rgba(255,255,255,0.6),0_0_4px_rgba(255,255,255,0.9)] animate-[dotGlow_2.4s_ease-in-out_infinite]"></span>
  </div>

  <!-- Hint text -->
  <div class="flex flex-col items-center gap-1 animate-[floatY_3s_ease-in-out_infinite]">
    <p class="text-[11px] font-[600] text-white dark:text-white drop-shadow-[0_1px_6px_rgba(0,0,0,0.4)] whitespace-nowrap">
      Right-click anywhere
    </p>
    <p class="text-[10px] font-[400] text-white/70 dark:text-white/70 drop-shadow-[0_1px_4px_rgba(0,0,0,0.3)] whitespace-nowrap">
      Change background & appearance
    </p>
  </div>
</div>

<style is:global>
  @keyframes radarPulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(4);
      opacity: 0;
    }
  }

  @keyframes dotGlow {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 12px rgba(255, 255, 255, 0.6), 0 0 4px rgba(255, 255, 255, 0.9);
    }
    50% {
      opacity: 0.7;
      box-shadow: 0 0 20px rgba(255, 255, 255, 0.8), 0 0 8px rgba(255, 255, 255, 1);
    }
  }

  @keyframes floatY {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes fadeInHint {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  (function() {
    let hintDismissed = false;
    const hint = document.getElementById('right-click-hint');
    if (!hint) return;

    // Fade in on load after a short delay
    setTimeout(() => {
      if (!hintDismissed && window.scrollY <= 100) {
        hint.style.opacity = '1';
      }
    }, 800);

    // Permanently dismiss when user right-clicks
    function dismissHint() {
      hintDismissed = true;
      hint.style.opacity = '0';
      hint.style.transform = 'translateY(-10px)';
      document.removeEventListener('contextmenu', dismissHint);
      window.removeEventListener('scroll', handleScroll);
    }

    // Show/hide based on scroll position
    function handleScroll() {
      if (hintDismissed) return;
      if (window.scrollY > 100) {
        hint.style.opacity = '0';
        hint.style.transform = 'translateY(-10px)';
      } else {
        hint.style.opacity = '1';
        hint.style.transform = 'translateY(0)';
      }
    }

    document.addEventListener('contextmenu', dismissHint);
    window.addEventListener('scroll', handleScroll, { passive: true });
  })();
</script>
