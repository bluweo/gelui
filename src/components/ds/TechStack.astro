---

<DSCard title="Technology Stack" description="Platform & tooling powering the design system" span={4}>
  <div class="grid grid-cols-3 gap-3 max-[860px]:grid-cols-2 max-[540px]:grid-cols-1">
    {TECH.map((tech) => (
      <div class="group flex items-start gap-3.5 p-3.5 rounded-[var(--glass-radius-sm)] bg-white/[0.03] border border-[var(--glass-border)] transition-all duration-200 hover:bg-white/[0.06]">
        <div
          class="w-9 h-9 rounded-[10px] flex items-center justify-center shrink-0 transition-transform duration-200 group-hover:scale-110"
          style={`background: color-mix(in srgb, ${tech.color} 15%, transparent); color: ${tech.color};`}
        >
          <Fragment set:html={tech.icon} />
        </div>
        <div class="flex flex-col gap-0.5 min-w-0">
          <div class="flex items-center gap-2">
            <span class="text-[13px] font-[600] leading-tight">{tech.name}</span>
            <span class="text-[9px] font-[600] uppercase tracking-[0.05em] opacity-35 leading-none px-1.5 py-0.5 rounded-full bg-white/[0.06]">{tech.role}</span>
          </div>
          <span class="text-[11px] opacity-40 leading-snug">{tech.desc}</span>
        </div>
      </div>
    ))}
  </div>
</DSCard>
