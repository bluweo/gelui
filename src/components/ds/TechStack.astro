---
/**
 * TechStack — Technology partners grid with logos
 * Reference-style layout: left = title + description, right = logo cards grid
 * Usage: <TechStack />
 */
import DSCard from "./DSCard.astro";

const TECH = [
  {
    name: "Astro 5",
    role: "Framework",
    desc: "Island architecture with static-first rendering — ship zero JavaScript where you don't need it.",
    logo: "/logos/tech/astro-white.svg",
    url: "https://astro.build",
  },
  {
    name: "React 19",
    role: "Islands",
    desc: "Interactive components hydrated only where needed via Astro islands architecture.",
    logo: "/logos/tech/react-white.svg",
    url: "https://react.dev",
  },
  {
    name: "TypeScript",
    role: "Language",
    desc: "Full type safety across design tokens, components, hooks, and island props.",
    logo: "/logos/tech/typescript-white.svg",
    url: "https://typescriptlang.org",
  },
  {
    name: "Tailwind CSS v4",
    role: "Styling",
    desc: "@theme tokens, @utility classes, and @custom-variant — zero runtime CSS-in-JS.",
    logo: "/logos/tech/tailwindcss-white.svg",
    url: "https://tailwindcss.com",
  },
  {
    name: "shadcn/ui",
    role: "Primitives",
    desc: "Accessible Radix-based components, re-themed with gel glass styling and tokens.",
    logo: "/logos/tech/shadcn-white.svg",
    url: "https://ui.shadcn.com",
  },
  {
    name: "Iconsax",
    role: "Iconography",
    desc: "1000+ icons with Bulk, Bold, and Linear variants for consistent visual language.",
    logo: "/logos/tech/iconsax-white.svg",
    url: "https://iconsax.io",
  },
];
---

<DSCard span={4} frost={true} frostHeight="220px">
  <div class="grid grid-cols-[1fr_2fr] gap-8 max-[860px]:grid-cols-1 max-[860px]:gap-6">

    {/* ── Left: Title + description ── */}
    <div class="flex flex-col pt-4 pl-3">
      <span class="text-[10px] font-[650] uppercase tracking-[0.1em] text-black/40 dark:text-white/40 mb-2">Built with</span>
      <h2 class="text-[28px] max-[540px]:text-[22px] font-[750] tracking-[-0.03em] leading-[1.2] text-black dark:text-white mb-3">
        Technology Stack
      </h2>
      <p class="text-[13px] leading-[1.65] text-black/55 dark:text-white/55 max-w-[300px]">
        Powered by modern web standards and best-in-class open source tools. Every layer is chosen for performance, developer experience, and design fidelity.
      </p>
    </div>

    {/* ── Right: Logo card grid ── */}
    <div class="grid grid-cols-3 gap-3 max-[640px]:grid-cols-2">
      {TECH.map((tech) => (
        <a
          href={tech.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col rounded-[var(--glass-radius-sm)] bg-white dark:bg-[#1a1a24] border border-black/30 dark:border-black/30 overflow-hidden no-underline transition-all duration-250 hover:shadow-[0_4px_20px_rgba(0,0,0,0.08)] hover:scale-[1.02]"
        >
          <div class="w-full aspect-[4/3] bg-[#111111] dark:bg-white/[0.05] flex items-center justify-center">
            <img
              src={tech.logo}
              alt={tech.name}
              class="w-16 h-16 object-contain"
              loading="lazy"
            />
          </div>

          {/* Name + description — left aligned */}
          <div class="w-full px-4 py-3">
            <span class="text-[15px] font-[620] text-black dark:text-white leading-tight block mb-1">{tech.name}</span>
            <p class="text-[13px] text-black/70 dark:text-white/70 leading-[1.55]">{tech.desc}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</DSCard>
