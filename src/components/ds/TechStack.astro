    icon: `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M22 8.27v7.45c0 .14-.08.27-.2.33l-4.76 2.44a.38.38 0 0 1-.38 0L12 16.02l-4.66 2.47a.38.38 0 0 1-.38 0L2.2 16.05a.38.38 0 0 1-.2-.33V8.27c0-.14.08-.27.2-.33L6.96 5.5a.38.38 0 0 1 .38 0L12 7.97l4.66-2.47a.38.38 0 0 1 .38 0l4.76 2.44c.12.06.2.2.2.33z" opacity=".35"/><path d="M12 7.97v8.05M2 8.27l10 3.75m10-3.75-10 3.75" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>`,
